@implements IDisposable
@inject IEnumerable<ISliceStatusSource> Sources

<a class="status-dot @Css" href="/status" title="@Title" aria-label="Systemstatus: @Title"></a>

@code {
    // Dezente Ampel (FA-11.04): aggregiert nur die Stale-Zustände der State-Quellen.
    // Token-/Backfill-Details stehen auf /status — hierhin führt der Tap.
    private string Css => Sources.Any(s => s.HasData && s.IsStale) ? "is-warn"
        : Sources.Any(s => s.HasData) ? "is-ok"
        : "is-idle";

    private string Title
    {
        get
        {
            var stale = Sources.Count(s => s.HasData && s.IsStale);
            return stale > 0 ? $"{stale} Datenquelle(n) veraltet" : "Datenquellen aktuell";
        }
    }

    protected override void OnInitialized()
    {
        foreach (var source in Sources)
        {
            source.Changed += OnChanged;
        }
    }

    private void OnChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        foreach (var source in Sources)
        {
            source.Changed -= OnChanged;
        }
    }
}
