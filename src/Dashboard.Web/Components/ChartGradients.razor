@* Versteckte SVG-<defs> mit den vertikalen Flächenverläufen je Domäne (oben ~.38 → unten 0).
   Einmal pro Layout einbinden; Flächencharts referenzieren sie per fill="url(#gGreen)" usw. *@
<svg width="0" height="0" class="chart-gradients" aria-hidden="true" focusable="false">
    <defs>
        <linearGradient id="gGreen" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#5fce97" stop-opacity=".38" />
            <stop offset="1" stop-color="#5fce97" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="gTeal" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#4fbdb0" stop-opacity=".38" />
            <stop offset="1" stop-color="#4fbdb0" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="gGold" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#e2b45f" stop-opacity=".38" />
            <stop offset="1" stop-color="#e2b45f" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="gBrown" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#c47b38" stop-opacity=".40" />
            <stop offset="1" stop-color="#c47b38" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="gCoral" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#e07d6f" stop-opacity=".38" />
            <stop offset="1" stop-color="#e07d6f" stop-opacity="0" />
        </linearGradient>
    </defs>
</svg>
