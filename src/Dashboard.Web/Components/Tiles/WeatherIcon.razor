@using Dashboard.Domain.Weather

@* Line-style weather glyphs (inherit currentColor → paper ink). Replaces the emoji
   set on the e-ink home. One 24×24 viewBox per condition. *@
<svg class="wx-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
     stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"
     role="img" aria-label="@Label">
    @switch (Condition)
    {
        case WeatherCondition.Clear:
            <circle cx="12" cy="12" r="4.2" />
            <line x1="12" y1="2" x2="12" y2="4" />
            <line x1="12" y1="20" x2="12" y2="22" />
            <line x1="4.2" y1="4.2" x2="5.6" y2="5.6" />
            <line x1="18.4" y1="18.4" x2="19.8" y2="19.8" />
            <line x1="2" y1="12" x2="4" y2="12" />
            <line x1="20" y1="12" x2="22" y2="12" />
            <line x1="4.2" y1="19.8" x2="5.6" y2="18.4" />
            <line x1="18.4" y1="5.6" x2="19.8" y2="4.2" />
            break;

        case WeatherCondition.Rain:
            <path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25" />
            <line x1="8" y1="18" x2="8" y2="21" />
            <line x1="12" y1="18" x2="12" y2="22" />
            <line x1="16" y1="18" x2="16" y2="21" />
            break;

        case WeatherCondition.Drizzle:
            <path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25" />
            <line x1="8" y1="19" x2="8" y2="20.5" />
            <line x1="12" y1="19" x2="12" y2="20.5" />
            <line x1="16" y1="19" x2="16" y2="20.5" />
            break;

        case WeatherCondition.Thunderstorm:
            <path d="M19 16.9A5 5 0 0 0 18 7h-1.26a8 8 0 1 0-11.62 9" />
            <polyline points="13 11 9 17 14 17 10 23" />
            break;

        case WeatherCondition.Snow:
            <path d="M20 17.58A5 5 0 0 0 18 8h-1.26A8 8 0 1 0 4 16.25" />
            <line x1="8" y1="17" x2="8.01" y2="17" />
            <line x1="12" y1="19" x2="12.01" y2="19" />
            <line x1="16" y1="17" x2="16.01" y2="17" />
            break;

        case WeatherCondition.Mist:
            <line x1="3" y1="8" x2="18" y2="8" />
            <line x1="5" y1="12" x2="21" y2="12" />
            <line x1="3" y1="16" x2="16" y2="16" />
            break;

        default: // Clouds / Unknown
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired] public WeatherCondition Condition { get; set; }

    private string Label => Condition switch
    {
        WeatherCondition.Clear => "klar",
        WeatherCondition.Rain => "Regen",
        WeatherCondition.Drizzle => "Nieselregen",
        WeatherCondition.Thunderstorm => "Gewitter",
        WeatherCondition.Snow => "Schnee",
        WeatherCondition.Mist => "Nebel",
        _ => "bewölkt",
    };
}
