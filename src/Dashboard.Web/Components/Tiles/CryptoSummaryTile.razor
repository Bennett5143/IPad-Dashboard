@implements IDisposable
@inject CryptoState CryptoState

@* Krypto-Summary: Leit-Münze (BTC) Preis + 24h-% + Markt-Mood-Badge.
   Ganze Kachel tippbar → /crypto (Watchlist + Fear-&-Greed-Gauge). *@
<a class="tile-tap @CssClass" href="/crypto">
    <Tile CssClass="tile--crypto">
        <div class="crypto-tile">
            @if (_coin is null)
            {
                <p class="crypto-empty">Kursdaten gerade nicht verfügbar.</p>
            }
            else
            {
                var up = _coin.Change24hPct >= 0;
                <div class="crypto-top">
                    <span class="cap">
                        <span class="chip chip--brown">
                            <svg width="15" height="15" viewBox="0 0 16 16"><rect x="4.5" y="4.5" width="7" height="7" rx="1.4" transform="rotate(45 8 8)" fill="none" stroke="currentColor" stroke-width="1.5" /></svg>
                        </span>
                        <span class="mono-label mono-label--brown">@_coin.Symbol</span>
                    </span>
                    <span class="crypto-pill @(up ? "is-up" : "is-down")">@CryptoFormatter.Percent(_coin.Change24hPct)</span>
                </div>
                <div class="crypto-bottom">
                    <span class="crypto-price">@CryptoFormatter.Price(_coin.PriceEur)</span>
                    <Sparkline Values="_coin.Sparkline7d" GradientId="@(up ? "gGreen" : "gCoral")"
                               CssClass="@($"crypto-spark {(up ? "is-up" : "is-down")}")" />
                </div>
            }
        </div>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private CoinQuote? _coin;

    protected override void OnInitialized()
    {
        CryptoState.Changed += OnChanged;
        ReadState();
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState() => _coin = CryptoState.Current?.Summary;

    public void Dispose() => CryptoState.Changed -= OnChanged;
}
