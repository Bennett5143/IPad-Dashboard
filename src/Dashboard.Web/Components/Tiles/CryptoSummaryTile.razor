@implements IDisposable
@inject CryptoState CryptoState

@* Krypto-Summary: Leit-Münze (BTC) Preis + 24h-% + Markt-Mood-Badge.
   Ganze Kachel tippbar → /crypto (Watchlist + Fear-&-Greed-Gauge). *@
<a class="tile-tap @CssClass" href="/crypto">
    <Tile Title="Krypto">
        <Icon>
            <span aria-hidden="true">₿</span>
        </Icon>
        <ChildContent>
            <div class="crypto-summary">
                @if (_coin is null)
                {
                    <p class="crypto-summary-empty">Kursdaten gerade nicht verfügbar.</p>
                }
                else
                {
                    <div class="crypto-summary-head">
                        <span class="crypto-summary-symbol">@_coin.Symbol</span>
                        <span class="crypto-summary-price">@CryptoFormatter.Price(_coin.PriceEur)</span>
                    </div>
                    <div class="crypto-summary-meta">
                        <span class="crypto-summary-change @CryptoFormatter.MoodClass(_coin.Direction)">
                            @CryptoFormatter.Percent(_coin.Change24hPct)
                        </span>
                        @if (_sentiment is not null)
                        {
                            <span class="crypto-summary-mood @CryptoFormatter.MoodClass(_sentiment.Mood)">
                                @CryptoFormatter.MoodLabel(_sentiment.Mood)
                            </span>
                        }
                    </div>
                }
            </div>
        </ChildContent>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private CoinQuote? _coin;
    private MarketSentiment? _sentiment;

    protected override void OnInitialized()
    {
        CryptoState.Changed += OnChanged;
        ReadState();
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState()
    {
        var snapshot = CryptoState.Current;
        _coin = snapshot?.Summary;
        _sentiment = snapshot?.Sentiment;
    }

    public void Dispose() => CryptoState.Changed -= OnChanged;
}
