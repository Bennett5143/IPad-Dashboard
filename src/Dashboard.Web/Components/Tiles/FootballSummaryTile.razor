@implements IDisposable
@inject FootballState FootballState
@inject IFabrizioAlertSource FabrizioAlerts

@* Fußball-Summary: Zähler „interessante Spiele diese Woche" + (ab 15.8) Fabrizio-Alert-Badge.
   Ganze Kachel tippbar → /football (Top-5-Tabellen + getrackte Vereine). *@
<a class="tile-tap @CssClass" href="/football">
    <Tile CssClass="tile--gold">
        <div class="football-tile">
            <span class="cap">
                <span class="chip chip--gold">
                    <svg width="15" height="15" viewBox="0 0 16 16">
                        <circle cx="8" cy="8" r="5.2" fill="none" stroke="currentColor" stroke-width="1.5" />
                        <polygon points="8,5 10.2,7 9.3,9.6 6.7,9.6 5.8,7" fill="currentColor" />
                    </svg>
                </span>
                <span class="mono-label mono-label--gold">Fußball</span>
            </span>
            @if (_snapshot is null)
            {
                <p class="football-empty">Fußballdaten gerade nicht verfügbar.</p>
            }
            else
            {
                <div class="football-count">
                    <span class="football-number">@_snapshot.InterestingGamesThisWeek</span>
                    <span class="football-count-label">
                        @(_snapshot.InterestingGamesThisWeek == 1 ? "Spiel diese Woche" : "Spiele diese Woche")
                    </span>
                </div>

                @if (_snapshot.InterestingGamesThisWeek == 0)
                {
                    <span class="football-hint">Saisonpause – keine Spiele deiner Vereine</span>
                }

                @if (_alert is not null)
                {
                    <div class="football-alert" title="@_alert.Headline">
                        <span class="football-alert-tag">Fabrizio</span>
                        <span class="football-alert-text">@_alert.Headline</span>
                    </div>
                }
            }
        </div>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private FootballSnapshot? _snapshot;
    private FabrizioAlert? _alert;

    protected override void OnInitialized()
    {
        FootballState.Changed += OnChanged;
        ReadState();
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState()
    {
        _snapshot = FootballState.Current;
        _alert = FabrizioAlerts.Latest;
    }

    public void Dispose() => FootballState.Changed -= OnChanged;
}
