@implements IDisposable
@inject HvvState HvvState

@* HVV-Summary: pro Haltestelle der nächste BUS (Richtung egal), soonest-first. Andere
   Verkehrsmittel (S-/U-Bahn) nur auf der Detailseite. Ganze Kachel tippbar → /hvv. *@
<a class="tile-tap @CssClass" href="/hvv">
    <Tile>
        <div class="hvv-tile">
            <span class="cap">
                <span class="chip chip--green">
                    <svg width="15" height="15" viewBox="0 0 16 16">
                        <rect x="3" y="3.5" width="10" height="7.5" rx="2" fill="none" stroke="currentColor" stroke-width="1.4" />
                        <line x1="3" y1="7.2" x2="13" y2="7.2" stroke="currentColor" stroke-width="1.2" />
                    </svg>
                </span>
                <span class="mono-label mono-label--green">Nächste Busse</span>
            </span>
            @if (_departures is null)
            {
                <p class="hvv-empty">Abfahrten gerade nicht verfügbar.</p>
            }
            else if (_departures.Count == 0)
            {
                <p class="hvv-empty">Kein Bus im Zeitfenster.</p>
            }
            else
            {
                <div class="hvv-list">
                    @for (var i = 0; i < _departures.Count; i++)
                    {
                        var d = _departures[i];
                        var badge = HvvFormatter.DelayBadge(d);
                        <div class="hvv-row">
                            <span class="hvv-line">@d.LineName</span>
                            <span class="hvv-dir">@d.Direction</span>
                            <span class="hvv-when @(i == 0 ? "is-next" : null)">
                                <time>@HvvFormatter.Time(d)</time>
                                @if (badge is not null)
                                {
                                    <span class="hvv-delay">@badge</span>
                                }
                            </span>
                        </div>
                    }
                </div>
            }
        </div>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private IReadOnlyList<Departure>? _departures;   // null = Daten nicht verfügbar

    protected override void OnInitialized()
    {
        HvvState.Changed += OnChanged;
        ReadState();
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState()
    {
        var available = HvvState.Current?.Stations.Where(s => s.Available).ToList();
        if (available is null || available.Count == 0)
        {
            _departures = null;
            return;
        }

        // Pro Haltestelle der nächste Bus; Stationen ohne Bus fallen raus; global soonest-first.
        _departures = available
            .Select(s => s.Departures
                .Where(d => d.Mode == TransportMode.Bus)
                .OrderBy(d => d.ExpectedTime)
                .FirstOrDefault())
            .OfType<Departure>()
            .OrderBy(d => d.ExpectedTime)
            .ToList();
    }

    public void Dispose() => HvvState.Changed -= OnChanged;
}
