@implements IAsyncDisposable
@inject HabitTrackingService HabitService

<Tile CssClass="@CssClass">
    <div class="habits-tile">
        <div class="habits-header">
            <h2 class="habits-title">Sport Habits</h2>
            <button type="button" class="backfill-open" @onclick="() => _backfillOpen = true">
                ＋ Nachtragen
            </button>
        </div>

        @if (_summaries is null)
        {
            <p class="habits-loading">Laden…</p>
        }
        else
        {
            <div class="habit-grid">
                @foreach (var summary in _summaries)
                {
                    <button type="button"
                            class="habit-card @(summary.IsDoneToday ? "is-done" : "")"
                            @onclick="() => OnCardClick(summary)"
                            disabled="@(_isToggling && !OpensDialog(summary.Kind))">
                        <span class="habit-name">@DisplayName(summary.Kind)</span>
                        <span class="habit-status">@StatusText(summary)</span>
                        <span class="habit-counts">W @summary.WeekCount · J @summary.YearCount</span>
                    </button>
                }
            </div>
        }

        <a class="habits-heatmap" href="/heatmap">🗺️ Lauf-Heatmap ansehen</a>
    </div>
</Tile>

@if (_gymDialogOpen && _dialogSummary is not null)
{
    <GymDetailDialog Date="_loadedFor" Summary="_dialogSummary"
                     OnChanged="OnDialogChangedAsync" OnClose="() => _gymDialogOpen = false" />
}
@if (_runDialogOpen && _dialogSummary is not null)
{
    <RunDetailDialog Date="_loadedFor" Summary="_dialogSummary"
                     OnChanged="OnDialogChangedAsync" OnClose="() => _runDialogOpen = false" />
}
@if (_backfillOpen)
{
    <BackfillDialog OnChanged="OnDialogChangedAsync" OnClose="() => _backfillOpen = false" />
}

@code {
    [Parameter] public string? CssClass { get; set; }

    private HabitSummary? _dialogSummary;
    private bool _gymDialogOpen;
    private bool _runDialogOpen;
    private bool _backfillOpen;

    private IReadOnlyList<HabitSummary>? _summaries;
    private DateOnly _loadedFor;
    private bool _isToggling;
    private PeriodicTimer? _timer;
    private Task? _watcherTask;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(_cts.Token);
        _timer = new PeriodicTimer(TimeSpan.FromMinutes(1));
        _watcherTask = RunDayChangeWatcherAsync(_cts.Token);
    }

    private async Task LoadAsync(CancellationToken ct)
    {
        _loadedFor = HabitService.GetCurrentLocalDate();
        _summaries = await HabitService.GetSummaryForAsync(_loadedFor, ct);
    }

    private async Task ToggleAsync(HabitKind kind)
    {
        if (_isToggling) return;          // schützt vor Doppelklick
        _isToggling = true;
        try
        {
            await HabitService.ToggleAsync(_loadedFor, kind, _cts.Token);
            await LoadAsync(_cts.Token);
        }
        finally
        {
            _isToggling = false;
        }
    }

    private async Task RunDayChangeWatcherAsync(CancellationToken ct)
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync(ct))
            {
                if (HabitService.GetCurrentLocalDate() != _loadedFor)
                {
                    await LoadAsync(ct);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _timer?.Dispose();
        if (_watcherTask is not null) await _watcherTask;
        _cts.Dispose();
    }

    private static string DisplayName(HabitKind kind) => kind switch
    {
        HabitKind.Strength        => "Gym",
        HabitKind.Zone2Run        => "Z2-Lauf",
        HabitKind.Vo2MaxIntervals => "VO2 Max",
        HabitKind.JumpRope        => "Jumping Rope",
        HabitKind.Stretching      => "Stretching",
        _                         => kind.ToString()
    };

    private static bool OpensDialog(HabitKind kind)
        => kind is HabitKind.Strength or HabitKind.Zone2Run or HabitKind.Vo2MaxIntervals;

    private async Task OnCardClick(HabitSummary summary)
    {
        switch (summary.Kind)
        {
            case HabitKind.Strength:
                _dialogSummary = summary; _gymDialogOpen = true; break;
            case HabitKind.Zone2Run:
            case HabitKind.Vo2MaxIntervals:
                _dialogSummary = summary; _runDialogOpen = true; break;
            default:
                await ToggleAsync(summary.Kind); break;
        }
    }

    private async Task OnDialogChangedAsync()
    {
        _gymDialogOpen = _runDialogOpen = _backfillOpen = false;
        await LoadAsync(_cts.Token);
    }

    private static string StatusText(HabitSummary s)
    {
        if (s.Kind == HabitKind.Strength)
            return s.TodaysEmom is not null ? "EMOM ✓" : s.IsDoneToday ? "Done ✓" : "·";
        if (s.Kind is HabitKind.Zone2Run or HabitKind.Vo2MaxIntervals)
            return s.TodaysRunning is { } r ? $"{r.DurationMinutes} min ✓"
                : s.IsDoneToday ? "Done ✓" : "·";
        return s.IsDoneToday ? "Done Today: ✓" : "Done Today: ·";
    }
}