@implements IDisposable
@inject FootballState FootballState

<Tile CssClass="@CssClass" Title="Fußball">
    <Icon>
        <span class="football-emoji" aria-hidden="true">⚽</span>
    </Icon>
    <ChildContent>
        <div class="football-tile">
            @if (_snapshot is null || _snapshot.Teams.Count == 0)
            {
                <p class="football-unavailable">Fußballdaten gerade nicht verfügbar.</p>
            }
            else
            {
                @foreach (var team in _snapshot.Teams)
                {
                    <section class="football-team">
                        <header>
                            <h3>@team.TeamName</h3>
                            @if (team.Table is { Count: > 0 })
                            {
                                <button class="football-position is-button" title="Ligatabelle anzeigen"
                                        @onclick="() => _openTable = team">
                                    🏆 @FootballFormatter.Position(team.Standing)
                                </button>
                            }
                            else
                            {
                                <span class="football-position" title="Tabellenplatz">🏆 @FootballFormatter.Position(team.Standing)</span>
                            }
                        </header>

                        @if (team.RecentResults.Count > 0)
                        {
                            <span class="football-label">Letzte</span>
                            <ul class="match-list">
                                @foreach (var match in team.RecentResults)
                                {
                                    <li class="match">
                                        <span class="match-date">@FootballFormatter.ShortDate(match.KickoffUtc)</span>
                                        <span class="match-opp">@match.Opponent <span class="match-venue">(@FootballFormatter.Venue(match))</span></span>
                                        <span class="match-comp">@FootballFormatter.Competition(match.CompetitionCode)</span>
                                        <span class="match-score @FootballFormatter.OutcomeCss(match.Outcome)">@FootballFormatter.Score(match)</span>
                                    </li>
                                }
                            </ul>
                        }

                        @if (team.Upcoming.Count > 0)
                        {
                            <span class="football-label">Nächste</span>
                            <ul class="match-list">
                                @foreach (var match in team.Upcoming)
                                {
                                    <li class="match">
                                        <span class="match-date">@FootballFormatter.DateTimeLabel(match.KickoffUtc)</span>
                                        <span class="match-opp">@match.Opponent <span class="match-venue">(@FootballFormatter.Venue(match))</span></span>
                                        <span class="match-comp">@FootballFormatter.Competition(match.CompetitionCode)</span>
                                    </li>
                                }
                            </ul>
                        }
                    </section>
                }

                @if (_isStale && _snapshot is not null)
                {
                    <small class="football-stale">Stand @FootballFormatter.UpdatedAt(_snapshot.RetrievedAtUtc) — Aktualisierung fehlgeschlagen</small>
                }
            }
        </div>
    </ChildContent>
</Tile>

@if (_openTable is { Table: { Count: > 0 } table } team)
{
    <div class="table-overlay" @onclick="() => _openTable = null">
        <div class="table-modal" @onclick:stopPropagation="true">
            <header class="table-modal-head">
                <h3>@team.TeamName · Tabelle</h3>
                <button class="table-close" @onclick="() => _openTable = null" aria-label="Schließen">✕</button>
            </header>
            <table class="league-table">
                <thead>
                    <tr>
                        <th class="num">#</th>
                        <th>Verein</th>
                        <th class="num">Sp</th>
                        <th class="num">S</th>
                        <th class="num">U</th>
                        <th class="num">N</th>
                        <th class="num">Diff</th>
                        <th class="num">Pkt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in table)
                    {
                        <tr class="@(row.IsOwnTeam ? "is-own" : null)">
                            <td class="num">@row.Position</td>
                            <td>@(row.ShortCode ?? row.TeamName)</td>
                            <td class="num">@row.PlayedGames</td>
                            <td class="num">@row.Won</td>
                            <td class="num">@row.Draw</td>
                            <td class="num">@row.Lost</td>
                            <td class="num">@(row.GoalDifference > 0 ? "+" : "")@row.GoalDifference</td>
                            <td class="num pts">@row.Points</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public string? CssClass { get; set; }

    private FootballSnapshot? _snapshot;
    private bool _isStale;
    private FootballTeamSnapshot? _openTable;

    protected override void OnInitialized()
    {
        FootballState.Changed += OnFootballChanged;
        ReadState();
    }

    private void OnFootballChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState()
    {
        _snapshot = FootballState.Current;
        _isStale = FootballState.IsStale;
    }

    public void Dispose() => FootballState.Changed -= OnFootballChanged;
}
