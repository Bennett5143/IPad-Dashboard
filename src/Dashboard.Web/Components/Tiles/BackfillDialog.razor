@inject HabitTrackingService HabitService
@using Dashboard.Domain.Habits
@* ggf. @using für deinen Entities-Namespace *@

<div class="dialog-backdrop" @onclick="OnClose">
    <div class="dialog" @onclick:stopPropagation="true">
        <h3 class="dialog-title">Nachtragen</h3>

        <label class="backfill-date">Datum
            <input type="date"
                   max="@_maxDate.ToString("yyyy-MM-dd")"
                   value="@_selectedDate.ToString("yyyy-MM-dd")"
                   @onchange="OnDateChanged" />
        </label>

        @if (_summaries is null)
        {
            <p>Laden…</p>
        }
        else
        {
            <div class="backfill-list">
                @foreach (var s in _summaries)
                {
                    <button type="button"
                            class="backfill-row @(s.IsDoneToday ? "is-done" : "")"
                            @onclick="() => ToggleAsync(s.Kind)"
                            disabled="@_busy">
                        <span>@DisplayName(s.Kind)</span>
                        <span>@(s.IsDoneToday ? "✓" : "·")</span>
                    </button>
                }
            </div>
        }

        <div class="dialog-actions">
            <button type="button" @onclick="OnClose">Fertig</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private DateOnly _selectedDate;
    private DateOnly _maxDate;
    private IReadOnlyList<HabitSummary>? _summaries;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        _maxDate = HabitService.GetCurrentLocalDate();
        _selectedDate = _maxDate;
        await LoadAsync();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
        {
            _selectedDate = d;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
        => _summaries = await HabitService.GetSummaryForAsync(_selectedDate);

    private async Task ToggleAsync(HabitKind kind)
    {
        _busy = true;
        try
        {
            await HabitService.ToggleAsync(_selectedDate, kind);
            await LoadAsync();
            await OnChanged.InvokeAsync();   // Haupt-Kachel neu laden: Counts ändern sich!
        }
        finally { _busy = false; }
    }

    private static string DisplayName(HabitKind kind) => kind switch
    {
        HabitKind.Strength        => "Gym",
        HabitKind.Zone2Run        => "Z2-Lauf",
        HabitKind.Vo2MaxIntervals => "VO2 Max",
        HabitKind.JumpRope        => "Jumping Rope",
        HabitKind.Stretching      => "Stretching",
        _                         => kind.ToString()
    };
}