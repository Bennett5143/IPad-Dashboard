@implements IDisposable
@inject WeatherState WeatherState

<Tile CssClass="@CssClass" Title="@TitleText">
    <Icon>
        <span class="weather-emoji" aria-hidden="true">@HeaderEmoji</span>
    </Icon>
    <ChildContent>
        <div class="weather-tile">
            @if (_snapshot is null)
            {
                <p class="weather-unavailable">Wetterdaten gerade nicht verfügbar.</p>
            }
            else
            {
                @if (Variant == WeatherVariant.Today)
                {
                    <div class="weather-current">
                        <div class="weather-now">
                            <span class="weather-now-emoji" aria-hidden="true">@WeatherFormatter.Emoji(_snapshot.Current.Condition)</span>
                            <span class="weather-now-temp">@WeatherFormatter.Temperature(_snapshot.Current.Temperature)</span>
                        </div>
                        <div class="weather-desc">@_snapshot.Current.Description</div>
                        <div class="weather-meta">
                            <span><span class="meta-label">Gefühlt</span> @WeatherFormatter.Temperature(_snapshot.Current.FeelsLike)</span>
                            <span><span class="meta-label">Min/Max</span> @WeatherFormatter.Temperature(_snapshot.Today.MinTemperature) / @WeatherFormatter.Temperature(_snapshot.Today.MaxTemperature)</span>
                            <span><span class="meta-label">Regen</span> @WeatherFormatter.Precipitation(_snapshot.Today.PrecipitationProbability)</span>
                            <span><span class="meta-label">Wind</span> @WeatherFormatter.Wind(_snapshot.Current.WindSpeedMs)</span>
                            <span><span class="meta-label">Luftf.</span> @WeatherFormatter.Humidity(_snapshot.Current.Humidity)</span>
                        </div>
                    </div>
                }
                else if (Variant == WeatherVariant.Hourly)
                {
                    @if (_snapshot.Hourly.Count == 0)
                    {
                        <p class="weather-unavailable">Keine Vorschau verfügbar.</p>
                    }
                    else
                    {
                        <ul class="weather-hourly">
                            @foreach (var hour in _snapshot.Hourly)
                            {
                                <li>
                                    <span class="hour-label">@WeatherFormatter.Hour(hour.Time)</span>
                                    <span class="hour-emoji" aria-hidden="true">@WeatherFormatter.Emoji(hour.Condition)</span>
                                    <span class="hour-temp">@WeatherFormatter.Temperature(hour.Temperature)</span>
                                    <span class="hour-precip">@WeatherFormatter.Precipitation(hour.PrecipitationProbability)</span>
                                </li>
                            }
                        </ul>
                    }
                }
                else
                {
                    @if (_snapshot.Tomorrow is { } tomorrow)
                    {
                        <div class="weather-tomorrow">
                            <span class="weather-tomorrow-emoji" aria-hidden="true">@WeatherFormatter.Emoji(tomorrow.Condition)</span>
                            <div class="weather-desc">@tomorrow.Description</div>
                            <div class="weather-meta">
                                <span><span class="meta-label">Min/Max</span> @WeatherFormatter.Temperature(tomorrow.MinTemperature) / @WeatherFormatter.Temperature(tomorrow.MaxTemperature)</span>
                                <span><span class="meta-label">Regen</span> @WeatherFormatter.Precipitation(tomorrow.PrecipitationProbability)</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="weather-unavailable">Vorhersage nicht verfügbar.</p>
                    }
                }

                @if (_isStale)
                {
                    <small class="weather-stale">Stand @WeatherFormatter.UpdatedAt(_snapshot.RetrievedAtUtc) — Aktualisierung fehlgeschlagen</small>
                }
            }
        </div>
    </ChildContent>
</Tile>

@code {
    public enum WeatherVariant { Today, Hourly, Tomorrow }

    [Parameter] public string? CssClass { get; set; }

    [Parameter, EditorRequired]
    public WeatherVariant Variant { get; set; }

    private WeatherSnapshot? _snapshot;
    private bool _isStale;

    protected override void OnInitialized()
    {
        WeatherState.Changed += OnWeatherChanged;
        ReadState();
    }

    private void OnWeatherChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState()
    {
        _snapshot = WeatherState.Current;
        _isStale = WeatherState.IsStale;
    }

    public void Dispose() => WeatherState.Changed -= OnWeatherChanged;

    private string TitleText => Variant switch
    {
        WeatherVariant.Today    => "Heute",
        WeatherVariant.Hourly   => "Verlauf (3-Std)",
        WeatherVariant.Tomorrow => "Morgen",
        _ => string.Empty
    };

    private string HeaderEmoji => Variant switch
    {
        WeatherVariant.Today    => _snapshot is null ? "⛅" : WeatherFormatter.Emoji(_snapshot.Current.Condition),
        WeatherVariant.Tomorrow => _snapshot?.Tomorrow is { } tomorrow ? WeatherFormatter.Emoji(tomorrow.Condition) : "⛅",
        _ => "🕒"
    };
}
