@implements IDisposable
@inject WhoopState WhoopState
@inject HabitTrackingService HabitService

@* Fitness-Summary: vier Kennzahlen als Fortschritts-Kreise – WHOOP Recovery / Schlaf /
   Strain + heute gemachte Habits. Ganze Kachel tippbar → /whoop (Insights-Hub). *@
<a class="tile-tap @CssClass" href="/whoop">
    <Tile Title="Fitness">
        <Icon>
            <span class="fitness-summary-emoji" aria-hidden="true">💪</span>
        </Icon>
        <ChildContent>
            <div class="fitness-summary">
                <div class="fitness-rings">
                    <MetricRing Label="Recovery" Center="@WhoopFormatter.RecoveryScore(_whoop?.Recovery)"
                                Fraction="@RecoveryFraction" ColorClass="@RecoveryColor" />
                    <MetricRing Label="Schlaf" Center="@SleepText" Fraction="@SleepFraction" />
                    <MetricRing Label="Strain" Center="@WhoopFormatter.Strain(_whoop?.DayStrain)" Fraction="@StrainFraction" />
                    <MetricRing Label="Habits" Center="@HabitsText" Fraction="@HabitsFraction" />
                </div>

                @if (_whoop is null)
                {
                    <small class="fitness-hint">WHOOP nicht verbunden</small>
                }
            </div>
        </ChildContent>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private WhoopSnapshot? _whoop;
    private int _habitsDone;
    private int _habitsTotal;
    private bool _reloadingHabits;

    protected override async Task OnInitializedAsync()
    {
        WhoopState.Changed += OnWhoopChanged;
        _whoop = WhoopState.Current;
        await LoadHabitsAsync();
    }

    private void OnWhoopChanged() => _ = InvokeAsync(async () =>
    {
        _whoop = WhoopState.Current;
        await LoadHabitsAsync();   // ein WHOOP-Refresh kann Habits automatisch füllen
        StateHasChanged();
    });

    private async Task LoadHabitsAsync()
    {
        if (_reloadingHabits)
        {
            return;
        }

        _reloadingHabits = true;
        try
        {
            var today = HabitService.GetCurrentLocalDate();
            var summaries = await HabitService.GetSummaryForAsync(today);
            _habitsDone = summaries.Count(s => s.IsDoneToday);
            _habitsTotal = summaries.Count;
        }
        finally
        {
            _reloadingHabits = false;
        }
    }

    // Recovery 0–100 %, farbcodiert nach WHOOP-Ampel.
    private double RecoveryFraction => _whoop?.Recovery is { } r ? r.ScorePercent / 100.0 : 0;
    private string RecoveryColor => _whoop?.Recovery?.Level switch
    {
        WhoopRecoveryLevel.High => "is-high",
        WhoopRecoveryLevel.Medium => "is-medium",
        WhoopRecoveryLevel.Low => "is-low",
        _ => string.Empty
    };

    // Schlaf-Performance 0–100 %.
    private string SleepText => _whoop?.Sleep is { } s ? $"{s.PerformancePercent}%" : "–";
    private double SleepFraction => _whoop?.Sleep is { } s ? s.PerformancePercent / 100.0 : 0;

    // Day-Strain auf der WHOOP-Skala 0–21.
    private double StrainFraction => _whoop?.DayStrain is { } d ? Math.Clamp(d / 21.0, 0, 1) : 0;

    // Heute abgehakte Habits / gesamt.
    private string HabitsText => $"{_habitsDone}/{_habitsTotal}";
    private double HabitsFraction => _habitsTotal > 0 ? (double)_habitsDone / _habitsTotal : 0;

    public void Dispose() => WhoopState.Changed -= OnWhoopChanged;
}
