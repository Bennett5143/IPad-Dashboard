@implements IAsyncDisposable
@inject IClock Clock

<Tile CssClass="@CssClass">
    <div class="clock-banner">
        <span class="clock-glow" aria-hidden="true"></span>
        <div class="clock-now">
            <time datetime="@_display.Iso" class="clock-time">@_display.TimeHm</time>
            <span class="clock-seconds">:@_display.Seconds</span>
        </div>
        <div class="clock-meta">
            <span class="clock-date">
                <span class="clock-chip" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16">
                        <circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.4" />
                        <line x1="8" y1="8" x2="8" y2="4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                        <line x1="8" y1="8" x2="10.5" y2="8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </svg>
                </span>
                <span class="clock-date-text">@_display.LongDate</span>
            </span>
            <span class="clock-sub">Hamburg · @_display.Week</span>
        </div>
    </div>
</Tile>

@code {
    [Parameter] public string? CssClass { get; set; }

    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    private ClockDisplay _display;
    private PeriodicTimer? _timer;
    private Task? _tickerTask;
    private readonly CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        _display = ClockFormatter.Format(Clock.UtcNow, BerlinTz);
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _tickerTask = RunTickerAsync(_cts.Token);
    }

    private async Task RunTickerAsync(CancellationToken ct)
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync(ct))
            {
                _display = ClockFormatter.Format(Clock.UtcNow, BerlinTz);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _timer?.Dispose();
        if (_tickerTask is not null) await _tickerTask;
        _cts.Dispose();
    }
}