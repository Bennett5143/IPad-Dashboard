        <time datetime="2026-05-19T14:23">
            <span class="clock-date">Di, 19.05.2026</span>
            <span class="clock-separator">·</span>
            <span class="clock-time">14:23</span>
        </time>
        <small class="placeholder-hint">Platzhalter — echte Uhr kommt in Phase 4.1</small>
