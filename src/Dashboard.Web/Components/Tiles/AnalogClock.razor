@implements IAsyncDisposable
@inject IClock Clock

@* e-ink analog clock: hairline face, ink hands, digital HH:MM below (no date).
   The hands are the ONLY moving element on the paper home. *@
<div class="analog-clock">
    <svg class="analog-face" viewBox="0 0 100 100" role="img" aria-label="@_hm Uhr">
        <circle class="face-rim" cx="50" cy="50" r="47" />
        @for (var i = 0; i < 12; i++)
        {
            var major = i % 3 == 0;
            <line class="tick @(major ? "tick--major" : null)"
                  x1="50" y1="6" x2="50" y2="@(major ? "13" : "10")"
                  transform="@($"rotate({(i * 30).ToString(Inv)} 50 50)")" />
        }
        <line class="hand hand--hour"   x1="50" y1="54" x2="50" y2="30"
              transform="@($"rotate({_hour.ToString(Inv)} 50 50)")" />
        <line class="hand hand--minute" x1="50" y1="56" x2="50" y2="18"
              transform="@($"rotate({_minute.ToString(Inv)} 50 50)")" />
        <line class="hand hand--second" x1="50" y1="58" x2="50" y2="15"
              transform="@($"rotate({_second.ToString(Inv)} 50 50)")" />
        <circle class="hand-cap" cx="50" cy="50" r="2.2" />
    </svg>
    <time class="analog-digital" datetime="@_iso">@_hm</time>
</div>

@code {
    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");
    private static readonly System.Globalization.CultureInfo Inv =
        System.Globalization.CultureInfo.InvariantCulture;

    private double _hour, _minute, _second;
    private string _hm = "", _iso = "";

    private PeriodicTimer? _timer;
    private Task? _tickerTask;
    private readonly CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        Recompute();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _tickerTask = RunTickerAsync(_cts.Token);
    }

    private void Recompute()
    {
        var now = TimeZoneInfo.ConvertTime(Clock.UtcNow, BerlinTz);
        var t = now.TimeOfDay;
        _second = t.Seconds * 6;                          // 360/60
        _minute = t.Minutes * 6 + t.Seconds * 0.1;        // + drift within the minute
        _hour = (t.Hours % 12) * 30 + t.Minutes * 0.5;    // 360/12 + drift within the hour
        _hm = now.ToString("HH:mm", Inv);
        _iso = now.ToString("yyyy-MM-ddTHH:mm:sszzz", Inv);
    }

    private async Task RunTickerAsync(CancellationToken ct)
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync(ct))
            {
                Recompute();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _timer?.Dispose();
        if (_tickerTask is not null) await _tickerTask;
        _cts.Dispose();
    }
}
