@implements IDisposable
@inject IEnumerable<Dashboard.Domain.Common.ISliceStatusSource> Sources

@* System-Summary: aggregierter Datenquellen-Status (aktuell / veraltet). Ganze Kachel
   tippbar → /status (Details, Warnungen). *@
<a class="tile-tap @CssClass" href="/status">
    <Tile>
        <div class="system-tile">
            <span class="cap">
                <span class="chip chip--green">
                    <svg width="15" height="15" viewBox="0 0 16 16">
                        <rect x="3" y="3" width="4.4" height="4.4" rx="1" fill="#5fce97" />
                        <rect x="8.6" y="3" width="4.4" height="4.4" rx="1" fill="#3f5a49" />
                        <rect x="3" y="8.6" width="4.4" height="4.4" rx="1" fill="#3f5a49" />
                        <rect x="8.6" y="8.6" width="4.4" height="4.4" rx="1" fill="#e2b45f" />
                    </svg>
                </span>
                <span class="mono-label">System</span>
            </span>
            <div class="system-lines">
                <span class="system-line">
                    <span class="system-dot is-ok"></span>@_fresh Quellen aktuell
                </span>
                @if (_stale > 0)
                {
                    <span class="system-line">
                        <span class="system-dot is-warn"></span>@_stale veraltet
                    </span>
                }
            </div>
        </div>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private int _fresh;
    private int _stale;

    protected override void OnInitialized()
    {
        foreach (var source in Sources)
        {
            source.Changed += OnChanged;
        }

        ReadState();
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        StateHasChanged();
    });

    private void ReadState()
    {
        _fresh = Sources.Count(s => s.HasData && !s.IsStale);
        _stale = Sources.Count(s => s.HasData && s.IsStale);
    }

    public void Dispose()
    {
        foreach (var source in Sources)
        {
            source.Changed -= OnChanged;
        }
    }
}
