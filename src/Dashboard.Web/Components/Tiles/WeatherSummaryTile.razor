@implements IDisposable
@inject WeatherState WeatherState

@* Wetter-Summary: groß & prägnant – aktuelle Temperatur, heute Min/Max, Regenwahrscheinlichkeit.
   Ganze Kachel tippbar → /weather (Verlauf + Morgen + Extras). *@
<a class="tile-tap @CssClass" href="/weather">
    <Tile Title="Wetter">
        <Icon>
            <span class="weather-summary-emoji" aria-hidden="true">@HeaderEmoji</span>
        </Icon>
        <ChildContent>
            <div class="weather-summary">
                @if (_snapshot is null)
                {
                    <p class="weather-summary-empty">Wetterdaten gerade nicht verfügbar.</p>
                }
                else
                {
                    <div class="weather-hero">
                        <span class="weather-hero-glyph" aria-hidden="true">@WeatherFormatter.Emoji(_snapshot.Current.Condition)</span>
                        <span class="weather-hero-temp">@WeatherFormatter.Temperature(_snapshot.Current.Temperature)</span>
                    </div>
                    <div class="weather-stats">
                        <div class="weather-stat">
                            <span class="weather-stat-value">@WeatherFormatter.Temperature(_snapshot.Today.MinTemperature) / @WeatherFormatter.Temperature(_snapshot.Today.MaxTemperature)</span>
                            <span class="weather-stat-label">Min / Max</span>
                        </div>
                        <div class="weather-stat">
                            <span class="weather-stat-value">@WeatherFormatter.Precipitation(_snapshot.Today.PrecipitationProbability)</span>
                            <span class="weather-stat-label">Regen</span>
                        </div>
                    </div>
                }
            </div>
        </ChildContent>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private WeatherSnapshot? _snapshot;

    protected override void OnInitialized()
    {
        WeatherState.Changed += OnChanged;
        _snapshot = WeatherState.Current;
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        _snapshot = WeatherState.Current;
        StateHasChanged();
    });

    public void Dispose() => WeatherState.Changed -= OnChanged;

    private string HeaderEmoji => _snapshot is null ? "⛅" : WeatherFormatter.Emoji(_snapshot.Current.Condition);
}
