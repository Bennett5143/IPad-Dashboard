@implements IDisposable
@inject WeatherState WeatherState

@* Wetter-Summary: groß & prägnant – aktuelle Temperatur, heute Min/Max, Regenwahrscheinlichkeit.
   Ganze Kachel tippbar → /weather (Verlauf + Morgen + Extras). *@
<a class="tile-tap @CssClass" href="/weather">
    <Tile CssClass="tile--teal">
        <div class="weather-hero-tile">
            @if (_snapshot is null)
            {
                <span class="cap">
                    <span class="chip chip-lg chip--teal">
                        <svg width="16" height="16" viewBox="0 0 16 16"><circle cx="8" cy="8" r="4.4" fill="none" stroke="currentColor" stroke-width="1.5" /></svg>
                    </span>
                    <span class="mono-label mono-label--teal">Wetter · Hamburg</span>
                </span>
                <p class="weather-empty">Wetterdaten gerade nicht verfügbar.</p>
            }
            else
            {
                var hourly = _snapshot.Hourly;
                var temps = hourly.Select(h => (double?)h.Temperature).ToList();
                var ticks = hourly.Where((_, i) => i % 2 == 0).Take(6).ToList();

                <span class="weather-glow" aria-hidden="true"></span>
                <div class="weather-top">
                    <span class="cap">
                        <span class="chip chip-lg chip--teal">
                            <svg width="16" height="16" viewBox="0 0 16 16"><circle cx="8" cy="8" r="4.4" fill="none" stroke="currentColor" stroke-width="1.5" /></svg>
                        </span>
                        <span class="mono-label mono-label--teal">Wetter · Hamburg</span>
                    </span>
                    <span class="weather-cond">@_snapshot.Current.Description</span>
                </div>

                <div class="weather-big">
                    <span class="weather-temp">@($"{Math.Round(_snapshot.Current.Temperature, MidpointRounding.AwayFromZero):0}")</span>
                    <span class="weather-unit">°C</span>
                </div>

                <div class="weather-chips">
                    <span class="wx-chip">@WeatherFormatter.Temperature(_snapshot.Today.MinTemperature) / @WeatherFormatter.Temperature(_snapshot.Today.MaxTemperature)</span>
                    <span class="wx-chip wx-chip--teal">Regen @WeatherFormatter.Precipitation(_snapshot.Today.PrecipitationProbability)</span>
                    <span class="wx-chip">Wind @WeatherFormatter.Wind(_snapshot.Current.WindSpeedMs)</span>
                </div>

                <div class="weather-spacer"></div>

                <span class="mono-label weather-chart-cap">Tagesverlauf</span>
                <Sparkline Values="temps" GradientId="gTeal" CssClass="weather-chart" />
                <div class="weather-ticks">
                    @foreach (var h in ticks)
                    {
                        <div class="weather-tick">
                            <span class="weather-tick-temp">@WeatherFormatter.Temperature(h.Temperature)</span>
                            <span class="weather-tick-hour">@($"{h.Time:HH}h")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </Tile>
</a>

@code {
    [Parameter] public string? CssClass { get; set; }

    private WeatherSnapshot? _snapshot;

    protected override void OnInitialized()
    {
        WeatherState.Changed += OnChanged;
        _snapshot = WeatherState.Current;
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        _snapshot = WeatherState.Current;
        StateHasChanged();
    });

    public void Dispose() => WeatherState.Changed -= OnChanged;
}
