@page "/football"
@implements IDisposable
@inject FootballState FootballState
@rendermode InteractiveServer

<PageTitle>Fußball</PageTitle>

<PageHeader Title="Fußball" Meta="BUNDESLIGA" />

<div class="detail-body is-scroll">
<div class="football-page">
    <div class="football-bar">
        <div class="football-tabs" role="tablist">
            @foreach (var (key, label) in Tabs())
            {
                <button class="football-tab @(_tab == key ? "is-active" : null)"
                        role="tab" aria-selected="@(_tab == key)" @onclick="() => _tab = key">
                    @label
                </button>
            }
        </div>
        <button class="football-toggle @(_showCrests ? "is-on" : null)"
                @onclick="() => _showCrests = !_showCrests"
                title="Vereinswappen / Flaggen ein- oder ausblenden">
            <svg class="football-toggle-icon" width="13" height="13" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 2 3 4v4c0 3 2.2 4.8 5 6 2.8-1.2 5-3 5-6V4L8 2Z" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
            </svg>
            Wappen @(_showCrests ? "an" : "aus")
        </button>
    </div>

    @if (_tab == "tables")
    {
        @if (_tables is { Count: > 0 })
        {
            <TableFilter Tables="_tables" ShowCrests="_showCrests" />
        }
        else
        {
            <p class="football-page-empty">Tabellen gerade nicht verfügbar.</p>
        }
    }
    else if (_tab == "cl" && _cl is not null)
    {
        <div class="football-comp">
            @if (_cl.LeaguePhase is { Rows.Count: > 0 } phase)
            {
                <TableFilter Tables="@(new[] { phase })" ShowCrests="_showCrests" />
            }
            @if (_cl.Bracket is not null)
            {
                <section class="football-card football-card-wide">
                    <h2>K.o.-Runde</h2>
                    <KnockoutBracketView Bracket="_cl.Bracket" ShowCrests="_showCrests" />
                </section>
            }
        </div>
    }
    else if (_tab.StartsWith("t:", StringComparison.Ordinal) && CurrentTournament() is { } tournament)
    {
        <div class="football-comp">
            @if (tournament.Groups.Count > 0)
            {
                <TableFilter Tables="tournament.Groups" ShowCrests="_showCrests" />
            }
            @if (tournament.Bracket is not null)
            {
                <section class="football-card football-card-wide">
                    <h2>K.o.-Runde</h2>
                    <KnockoutBracketView Bracket="tournament.Bracket" ShowCrests="_showCrests" />
                </section>
            }
        </div>
    }
    else if (_tab == "clubs")
    {
        <div class="football-clubs">
            <FootballTile ShowCrests="_showCrests" />
        </div>
    }
</div>
</div>

@code {
    private IReadOnlyList<LeagueTable>? _tables;
    private ChampionsLeague? _cl;
    private IReadOnlyList<TournamentView>? _tournaments;
    private string _tab = "tables";
    private bool _showCrests = true;

    protected override void OnInitialized()
    {
        FootballState.Changed += OnChanged;
        ReadState();
        _tab = DefaultTab();
    }

    private void OnChanged() => _ = InvokeAsync(() =>
    {
        ReadState();
        EnsureValidTab();
        StateHasChanged();
    });

    private void ReadState()
    {
        var snapshot = FootballState.Current;
        _tables = snapshot?.LeagueTables;
        _cl = snapshot?.Cl;
        _tournaments = snapshot?.Tournaments;
    }

    // Tab-Reihenfolge: Tabellen · Champions League · aktive Turniere · Vereine.
    private IReadOnlyList<(string Key, string Label)> Tabs()
    {
        var tabs = new List<(string, string)> { ("tables", "Tabellen") };
        if (_cl is not null)
        {
            tabs.Add(("cl", "Champions League"));
        }

        if (_tournaments is not null)
        {
            tabs.AddRange(_tournaments.Select(t => ($"t:{t.Code}", t.Name)));
        }

        tabs.Add(("clubs", "Vereine"));
        return tabs;
    }

    // Während ein Turnier läuft, ist es die Schlagzeile → als Standard-Tab.
    private string DefaultTab() =>
        _tournaments is { Count: > 0 } ? $"t:{_tournaments[0].Code}" : "tables";

    private void EnsureValidTab()
    {
        if (!Tabs().Any(t => t.Key == _tab))
        {
            _tab = DefaultTab();
        }
    }

    private TournamentView? CurrentTournament()
    {
        if (_tournaments is null || !_tab.StartsWith("t:", StringComparison.Ordinal))
        {
            return null;
        }

        var code = _tab[2..];
        return _tournaments.FirstOrDefault(t => t.Code == code);
    }

    public void Dispose() => FootballState.Changed -= OnChanged;
}
