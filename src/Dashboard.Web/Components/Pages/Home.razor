@page "/"
@layout KioskLayout
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<div class="dashboard">
    <TileBoundary CssClass="area-header">
        <ClockTile CssClass="area-header" />
    </TileBoundary>

    <TileBoundary CssClass="area-quote">
        <QuoteTile CssClass="area-quote" />
    </TileBoundary>

    <TileBoundary CssClass="area-hvv1">
        <HvvTile StationIndex="0" CssClass="area-hvv1" />
    </TileBoundary>

    <TileBoundary CssClass="area-hvv2">
        <HvvTile StationIndex="1" CssClass="area-hvv2" />
    </TileBoundary>

    <TileBoundary CssClass="area-hvv3">
        <HvvTile StationIndex="2" CssClass="area-hvv3" />
    </TileBoundary>

    <TileBoundary CssClass="area-habits">
        <HabitsTile CssClass="area-habits" />
    </TileBoundary>

    <TileBoundary CssClass="area-football">
        <FootballTile CssClass="area-football" />
    </TileBoundary>

    <TileBoundary CssClass="area-whoop">
        <WhoopTile CssClass="area-whoop" />
    </TileBoundary>

    <TileBoundary CssClass="area-weather">
        <WeatherTile Variant="WeatherTile.WeatherVariant.Today"
                     CssClass="area-weather" />
    </TileBoundary>

    <TileBoundary CssClass="area-hourly">
        <WeatherTile Variant="WeatherTile.WeatherVariant.Hourly"
                     CssClass="area-hourly" />
    </TileBoundary>

    <TileBoundary CssClass="area-tomorrow">
        <WeatherTile Variant="WeatherTile.WeatherVariant.Tomorrow"
                     CssClass="area-tomorrow" />
    </TileBoundary>
</div>