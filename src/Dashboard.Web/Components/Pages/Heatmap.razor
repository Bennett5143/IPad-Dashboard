@page "/heatmap"
@layout MainLayout
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IRunRepository RunRepository
@inject IRouteClusterStore RouteClusters
@inject IStravaTokenStore TokenStore
@inject ISyncStateStore SyncStateStore
@inject IClock Clock
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Lauf-Heatmap</PageTitle>

<div class="heatmap-page">
    <header class="heatmap-header">
        <h1>Lauf-Heatmap</h1>
    </header>

    @if (!_connected)
    {
        <div class="heatmap-connect">
            <p>Noch nicht mit Strava verbunden. Verbinde dein Konto, um deine Läufe zu synchronisieren.</p>
            <a class="btn-connect" href="/strava/connect">Mit Strava verbinden</a>
        </div>
    }
    else
    {
        <div class="heatmap-controls">
            @if (Cluster is null)
            {
                <div class="range-buttons" role="group" aria-label="Zeitraum">
                    <button class="@RangeCss(RunTimeRange.FourWeeks)" @onclick="() => SetRangeAsync(RunTimeRange.FourWeeks)">4 Wochen</button>
                    <button class="@RangeCss(RunTimeRange.TwelveMonths)" @onclick="() => SetRangeAsync(RunTimeRange.TwelveMonths)">12 Monate</button>
                    <button class="@RangeCss(RunTimeRange.All)" @onclick="() => SetRangeAsync(RunTimeRange.All)">Alle</button>
                </div>
            }
            else
            {
                <div class="cluster-banner">
                    <span>Standard-Runde · @_runs.Count Läufe</span>
                    <button class="cluster-reset" @onclick="ResetCluster">alle Läufe anzeigen</button>
                </div>
            }

            <div class="heatmap-stats">
                <div class="stat"><span class="stat-value">@_stats.RunCount</span><span class="stat-label">Läufe</span></div>
                <div class="stat"><span class="stat-value">@_stats.TotalDistanceKm.ToString("0.0", De) km</span><span class="stat-label">Distanz</span></div>
                <div class="stat"><span class="stat-value">@FormatPace(_stats.AveragePaceMinPerKm)</span><span class="stat-label">Ø Pace</span></div>
            </div>
        </div>

        <div class="layer-buttons" role="group" aria-label="Ebene">
            <button class="@LayerCss("heat")" @onclick='() => SetLayerAsync("heat")'>Heatmap</button>
            <button class="@LayerCss("pace")" @onclick='() => SetLayerAsync("pace")'>Pace</button>
            <button class="@LayerCss("elevation")" @onclick='() => SetLayerAsync("elevation")'>Höhe</button>
            <button class="@LayerCss("direction")" @onclick='() => SetLayerAsync("direction")'>Richtung</button>
            <button class="@LayerCss("heartrate")" @onclick='() => SetLayerAsync("heartrate")'>Herzfrequenz</button>
        </div>

        <div id="heatmap-map" class="heatmap-map"></div>

        <p class="heatmap-legend">@LegendText</p>
        <p class="heatmap-hint">Tipp auf eine Route zeigt Lauf-Details.</p>
        <p class="sync-info">@SyncInfo</p>
    }
</div>

@code {
    private static readonly System.Globalization.CultureInfo De =
        System.Globalization.CultureInfo.GetCultureInfo("de-DE");

    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    private const string MapElementId = "heatmap-map";

    /// <summary>Optionaler Filter: nur die Läufe dieser Standard-Runde anzeigen (Tap auf /runs).</summary>
    [Parameter, SupplyParameterFromQuery] public int? Cluster { get; set; }

    private bool _connected;
    private RunTimeRange _range = RunTimeRange.TwelveMonths;
    private string _layer = "heat";
    private IReadOnlyList<Run> _runs = [];
    private RunStats _stats = new(0, 0, TimeSpan.Zero, null);
    private SyncSnapshot _sync = new(null, null, null);
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        _connected = await TokenStore.HasTokensAsync();
        _sync = await SyncStateStore.GetAsync();
        if (_connected)
        {
            await LoadRunsAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _connected)
        {
            await RenderMapAsync();
        }
    }

    private async Task LoadRunsAsync()
    {
        if (Cluster is { } clusterId)
        {
            // Eine Runde anzeigen: alle Läufe dieses Clusters, unabhängig vom Zeitraum.
            var ids = (await RouteClusters.GetRunIdsForClusterAsync(clusterId)).ToHashSet();
            var all = await RunRepository.GetRunsAsync(null);
            _runs = all.Where(r => ids.Contains(r.Id)).ToList();
        }
        else
        {
            var cutoff = _range.CutoffUtc(Clock.UtcNow);
            _runs = await RunRepository.GetRunsAsync(cutoff);
        }

        _stats = RunStatsCalculator.Calculate(_runs);
    }

    private void ResetCluster() => Nav.NavigateTo("/heatmap", forceLoad: true);

    private async Task SetRangeAsync(RunTimeRange range)
    {
        if (range == _range)
        {
            return;
        }

        _range = range;
        await LoadRunsAsync();
        await RenderMapAsync();
    }

    private async Task RenderMapAsync()
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/heatmap.js");

        // Pro Lauf Punkte + (sofern vorhanden) Streams; die JS verbindet sie zu Linien und
        // färbt je nach Ebene segmentweise ein.
        var runs = HeatmapPayloadBuilder.Build(_runs);
        await _module.InvokeVoidAsync("render", MapElementId, runs, _layer);
    }

    private async Task SetLayerAsync(string layer)
    {
        if (layer == _layer)
        {
            return;
        }

        _layer = layer;
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("setLayer", MapElementId, _layer);
        }
    }

    private string RangeCss(RunTimeRange range) => range == _range ? "active" : string.Empty;

    private string LayerCss(string layer) => layer == _layer ? "active" : string.Empty;

    private string LegendText => _layer switch
    {
        "pace" => "Heller = schneller",
        "elevation" => "Heller = steiler",
        "direction" => "Lila = bergauf · Grün = bergab",
        "heartrate" => "Blau = niedrig · Rot = hoch",
        _ => "Heller = häufiger gelaufen"
    };

    private static string FormatPace(double? minPerKm)
    {
        if (minPerKm is not { } pace)
        {
            return "–";
        }

        var minutes = (int)pace;
        var seconds = (int)Math.Round((pace - minutes) * 60, MidpointRounding.AwayFromZero);
        if (seconds == 60)
        {
            minutes++;
            seconds = 0;
        }

        return $"{minutes}:{seconds:00} /km";
    }

    private string SyncInfo => _sync.LastSuccessfulSyncUtc is { } last
        ? $"Letzter Sync: {TimeZoneInfo.ConvertTime(last, BerlinTz):dd.MM.yyyy HH:mm}"
            + (_sync.LastError is null ? string.Empty : " · letzter Versuch fehlgeschlagen")
        : "Noch kein erfolgreicher Sync.";

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", MapElementId);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit bereits getrennt – nichts zu tun.
            }
        }
    }
}
