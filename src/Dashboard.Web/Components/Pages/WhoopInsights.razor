@page "/whoop"
@rendermode InteractiveServer
@inject IWhoopProvider Whoop
@inject IWhoopTokenStore Tokens
@inject IClock Clock

<PageTitle>WHOOP – Auswertungen</PageTitle>

<div class="insights">
    <header class="insights-header">
        <a class="insights-back" href="/">← Dashboard</a>
        <h1>WHOOP · letzte @WindowDays Tage</h1>
    </header>

    @if (!_connected)
    {
        <p class="insights-msg">WHOOP nicht verbunden – <a href="/whoop/connect">jetzt verbinden</a>.</p>
    }
    else if (_loading)
    {
        <p class="insights-msg">Lade WHOOP-Daten …</p>
    }
    else if (_error is not null)
    {
        <p class="insights-msg insights-error">Konnte WHOOP-Daten nicht laden: @_error</p>
    }
    else
    {
        <section class="metric-grid">
            @foreach (var card in _cards)
            {
                <article class="metric-card">
                    <div class="metric-head">
                        <span class="metric-title">@card.Title</span>
                        <span class="metric-current">@card.Current<span class="metric-unit">@card.Unit</span></span>
                    </div>
                    <Sparkline Values="card.Values" CssClass="@card.CssClass" />
                    <div class="metric-stats">
                        <span>Ø @card.Avg</span>
                        <span>min @card.Min</span>
                        <span>max @card.Max</span>
                    </div>
                </article>
            }
        </section>

        @if (_night is not null)
        {
            <section class="sleep">
                <h2>Letzte Nacht <span class="sleep-date">@_night.DateLabel</span></h2>
                <article class="sleep-card">
                    <div class="sleep-meta">
                        @if (_night.TimeRange is not null)
                        {
                            <span>@_night.TimeRange</span>
                        }
                        <span>@_night.AsleepLabel</span>
                        @if (_night.RespiratoryLabel is not null)
                        {
                            <span>@_night.RespiratoryLabel</span>
                        }
                    </div>
                    <div class="sleep-bar">
                        @foreach (var seg in _night.Segments)
                        {
                            <div class="sleep-seg @seg.CssClass"
                                 style="width: @(seg.WidthPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%"
                                 title="@seg.Label: @seg.Detail"></div>
                        }
                    </div>
                    <ul class="sleep-legend">
                        @foreach (var seg in _night.Segments)
                        {
                            <li>
                                <span class="sleep-swatch @seg.CssClass" aria-hidden="true"></span>
                                <span class="sleep-stage">@seg.Label</span>
                                <span class="sleep-detail">@seg.Detail</span>
                            </li>
                        }
                    </ul>
                </article>
            </section>
        }

        <section class="runs">
            <h2>Läufe nach Recovery</h2>
            @if (_runs.Count == 0)
            {
                <p class="insights-msg">Keine Läufe im Zeitraum.</p>
            }
            else
            {
                <ul class="run-list">
                    @foreach (var run in _runs)
                    {
                        <li class="run">
                            <span class="run-dot @run.RecoveryCss" title="Recovery"></span>
                            <span class="run-date">@run.Date</span>
                            <span class="run-kind">@run.Kind</span>
                            <span class="run-detail">@run.Detail</span>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>

@code {
    private const int WindowDays = 30;

    private bool _connected;
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<WhoopMetricCard> _cards = [];
    private IReadOnlyList<WhoopRunRow> _runs = [];
    private WhoopSleepNight? _night;

    protected override async Task OnInitializedAsync()
    {
        _connected = await Tokens.HasTokensAsync();
        if (!_connected)
        {
            _loading = false;
            return;
        }

        try
        {
            var now = Clock.UtcNow;
            var from = now.AddDays(-WindowDays);
            var history = await Whoop.GetHistoryAsync(from, now);
            var workouts = await Whoop.GetWorkoutsAsync(from, now);
            _cards = WhoopInsightsBuilder.BuildCards(history);
            _night = WhoopInsightsBuilder.BuildSleepNight(history);
            _runs = WhoopInsightsBuilder.BuildRuns(workouts, history);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
