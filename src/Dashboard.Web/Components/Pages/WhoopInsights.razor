@page "/whoop"
@layout DetailLayout
@rendermode InteractiveServer
@inject IWhoopProvider Whoop
@inject IWhoopMetricStore Metrics
@inject IWhoopWorkoutStore Workouts
@inject IWhoopTokenStore Tokens
@inject IRunRepository RunRepo
@inject IClock Clock

<PageTitle>WHOOP – Auswertungen</PageTitle>

<PageHeader Title="WHOOP" Accent="var(--accent-green)" Meta="@($"LETZTE {WindowDays} TAGE")" />

<div class="detail-body is-scroll insights">
    @if (!_connected)
    {
        <p class="insights-msg">WHOOP nicht verbunden – <a href="/whoop/connect">jetzt verbinden</a>.</p>
    }
    else if (_loading)
    {
        <p class="insights-msg">Lade WHOOP-Daten …</p>
    }
    else if (_error is not null)
    {
        <p class="insights-msg insights-error">Konnte WHOOP-Daten nicht laden: @_error</p>
    }
    else
    {
        <section class="metric-grid">
            @foreach (var card in _cards)
            {
                <Explainable Id="CardMetric(card.CssClass)">
                    <ChildContent>
                        <article class="metric-card">
                            <div class="metric-head">
                                <span class="metric-title">@card.Title</span>
                                <span class="metric-current">@card.Current<span class="metric-unit">@card.Unit</span></span>
                            </div>
                            <Sparkline Values="card.Values" CssClass="@card.CssClass" />
                            <div class="metric-stats">
                                <span>Ø @card.Avg</span>
                                <span>min @card.Min</span>
                                <span>max @card.Max</span>
                            </div>
                        </article>
                    </ChildContent>
                    <Detail>
                        <ChartFrame XLabel="Zeit · letzte 30 Tage" YLabel="@CardYAxis(card.CssClass)">
                            <Sparkline Values="card.Values" CssClass="@card.CssClass" />
                        </ChartFrame>
                    </Detail>
                </Explainable>
            }
        </section>

        @if (_trainingLoad is not null)
        {
            <section class="load">
                <h2>Trainingslast <span class="tod-window">ACWR · Tages-Strain</span></h2>
                <Explainable Id="MetricId.TrainingLoad">
                    <ChildContent>
                        <article class="tod-card">
                            <div class="load-head">
                                <span class="load-ratio @_trainingLoad.ZoneCss">@_trainingLoad.RatioLabel</span>
                                <span class="load-zone @_trainingLoad.ZoneCss">@_trainingLoad.ZoneLabel</span>
                            </div>
                            <Sparkline Values="_trainingLoad.Sparkline" CssClass="load" />
                            @if (_trainingLoad.ConfidenceHint is not null)
                            {
                                <p class="load-confidence">@_trainingLoad.ConfidenceHint</p>
                            }
                        </article>
                    </ChildContent>
                    <Detail>
                        <ChartFrame XLabel="Zeit · letzte ~90 Tage" YLabel="ACWR-Verhältnis">
                            <Sparkline Values="_trainingLoad.Sparkline" CssClass="load" />
                        </ChartFrame>
                    </Detail>
                </Explainable>
            </section>
        }

        @if (_fitnessCurve is not null)
        {
            <section class="load">
                <h2>Aerobe Fitness <span class="tod-window">Monats-Ø · letzte 12 Monate</span></h2>
                <Explainable Id="MetricId.AerobicFitness">
                    <ChildContent>
                        <article class="tod-card">
                            <div class="load-head">
                                <span class="fitness-current">@_fitnessCurve.CurrentLabel</span>
                                @if (_fitnessCurve.TrendLabel is not null)
                                {
                                    <span class="fitness-trend @_fitnessCurve.TrendCss">@_fitnessCurve.TrendLabel</span>
                                }
                            </div>
                            <Sparkline Values="_fitnessCurve.Sparkline" CssClass="fitness" />
                        </article>
                    </ChildContent>
                    <Detail>
                        <ChartFrame XLabel="Zeit · letzte 12 Monate" YLabel="Herzschläge/km">
                            <Sparkline Values="_fitnessCurve.Sparkline" CssClass="fitness" />
                        </ChartFrame>
                    </Detail>
                </Explainable>
            </section>
        }

        @if (_recoveryDrivers is not null)
        {
            <section class="tod">
                <h2>Recovery-Treiber <span class="tod-window">Korrelation · letzte 12 Monate</span></h2>
                <Explainable Id="MetricId.RecoveryDrivers">
                    <ChildContent>
                        <article class="tod-card drivers-card">
                            <ul class="drv-rows">
                                @foreach (var row in _recoveryDrivers.Rows)
                                {
                                    <li class="@(row.LowSample ? "is-thin" : null)">
                                        <span class="tod-bucket">@row.Label</span>
                                        <span class="tod-bar">
                                            <span class="tod-bar-fill"
                                                  style="width: @(row.BarPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></span>
                                        </span>
                                        <span class="tod-value">@row.RLabel</span>
                                        <span class="drv-strength">@row.StrengthLabel · n=@row.Count</span>
                                    </li>
                                }
                            </ul>
                        </article>
                    </ChildContent>
                </Explainable>

                @if (_recoveryDrivers.Scatters.Count > 0)
                {
                    <div class="tod-grid">
                        @foreach (var scatter in _recoveryDrivers.Scatters)
                        {
                            <article class="tod-card">
                                <div class="tod-head">
                                    <span class="tod-title">@scatter.Title</span>
                                    <span class="tod-hint">@scatter.AxisHint · n=@scatter.Count</span>
                                </div>
                                <Scatter Pairs="scatter.Pairs" CssClass="drivers" />
                            </article>
                        }
                    </div>
                }
            </section>
        }

        @if (_night is not null)
        {
            <section class="sleep">
                <h2>Letzte Nacht <span class="sleep-date">@_night.DateLabel</span></h2>
                <Explainable Id="MetricId.SleepNight"><ChildContent>
                <article class="sleep-card">
                    <div class="sleep-meta">
                        @if (_night.TimeRange is not null)
                        {
                            <span>@_night.TimeRange</span>
                        }
                        <span>@_night.AsleepLabel</span>
                        @if (_night.RespiratoryLabel is not null)
                        {
                            <span>@_night.RespiratoryLabel</span>
                        }
                    </div>
                    <div class="sleep-bar">
                        @foreach (var seg in _night.Segments)
                        {
                            <div class="sleep-seg @seg.CssClass"
                                 style="width: @(seg.WidthPercent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%"
                                 title="@seg.Label: @seg.Detail"></div>
                        }
                    </div>
                    <ul class="sleep-legend">
                        @foreach (var seg in _night.Segments)
                        {
                            <li>
                                <span class="sleep-swatch @seg.CssClass" aria-hidden="true"></span>
                                <span class="sleep-stage">@seg.Label</span>
                                <span class="sleep-detail">@seg.Detail</span>
                            </li>
                        }
                    </ul>
                </article>
                </ChildContent></Explainable>
            </section>
        }

        <section class="tod">
            <h2>Tageszeit-Effektivität <span class="tod-window">letzte 12 Monate</span></h2>
            @if (_todCards.Count == 0)
            {
                <p class="insights-msg">
                    Workout-Historie wird noch aufgebaut – Fortschritt auf <a href="/status">/status</a>.
                </p>
            }
            else
            {
                <div class="tod-grid">
                    @foreach (var card in _todCards)
                    {
                        <Explainable Id="MetricId.TimeOfDay"><ChildContent>
                        <article class="tod-card">
                            <div class="tod-head">
                                <span class="tod-title">@card.Title</span>
                                <span class="tod-hint">@card.MeasureHint</span>
                            </div>
                            <ul class="tod-rows">
                                @foreach (var row in card.Rows)
                                {
                                    <li class="@(row.IsBest ? "is-best" : null) @(row.LowSample ? "is-thin" : null)">
                                        <span class="tod-bucket">@row.BucketLabel</span>
                                        <span class="tod-bar">
                                            <span class="tod-bar-fill"
                                                  style="width: @(row.BarPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></span>
                                        </span>
                                        <span class="tod-value">@row.ValueLabel</span>
                                        <span class="tod-n">n=@row.Count</span>
                                    </li>
                                }
                            </ul>
                            <p class="tod-verdict">@card.Verdict</p>
                        </article>
                        </ChildContent></Explainable>
                    }
                </div>

                @if (_todMatrix is not null)
                {
                    <Explainable Id="MetricId.TimeOfDayMatrix"><ChildContent>
                    <table class="tod-matrix">
                        <thead>
                            <tr>
                                <th scope="col"></th>
                                @foreach (var day in _todMatrix.DayLabels)
                                {
                                    <th scope="col">@day</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _todMatrix.Rows)
                            {
                                <tr>
                                    <th scope="row">@row.BucketLabel</th>
                                    @foreach (var cell in row.Cells)
                                    {
                                        <td class="@cell.Css" title="@cell.Count Training(s)">
                                            @(cell.Count > 0 ? cell.Count : null)
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                    </ChildContent></Explainable>
                }
            }
        </section>

        <section class="tod">
            <h2>Schlafenszeiten <span class="tod-window">letzte 12 Monate</span></h2>
            @if (_sleepInsights is null)
            {
                <p class="insights-msg">
                    Schlaf-Historie wird noch aufgebaut – Fortschritt auf <a href="/status">/status</a>.
                </p>
            }
            else
            {
                @if (_sleepInsights.ConsistencyLabel is not null)
                {
                    <p class="tod-fact">@_sleepInsights.ConsistencyLabel</p>
                }

                <div class="tod-grid">
                    <Explainable Id="MetricId.SleepBedtime"><ChildContent>
                    <article class="tod-card">
                        <div class="tod-head">
                            <span class="tod-title">Einschlafzeit → Recovery</span>
                            <span class="tod-hint">Ø Recovery am Folgetag je Einschlaf-Fenster</span>
                        </div>
                        <ul class="tod-rows">
                            @foreach (var row in _sleepInsights.BedtimeRows)
                            {
                                <li class="@(row.IsBest ? "is-best" : null) @(row.LowSample ? "is-thin" : null)">
                                    <span class="tod-bucket">@row.Label</span>
                                    <span class="tod-bar">
                                        <span class="tod-bar-fill"
                                              style="width: @(row.BarPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></span>
                                    </span>
                                    <span class="tod-value">@row.ValueLabel</span>
                                    <span class="tod-n">n=@row.Count</span>
                                </li>
                            }
                        </ul>
                        <p class="tod-verdict">@_sleepInsights.BedtimeVerdict</p>
                    </article>
                    </ChildContent></Explainable>

                    <Explainable Id="MetricId.SleepDuration"><ChildContent>
                    <article class="tod-card">
                        <div class="tod-head">
                            <span class="tod-title">Schlafdauer → Recovery</span>
                            <span class="tod-hint">Ø Recovery je Schlafdauer</span>
                        </div>
                        <ul class="tod-rows">
                            @foreach (var row in _sleepInsights.DurationRows)
                            {
                                <li class="@(row.IsBest ? "is-best" : null) @(row.LowSample ? "is-thin" : null)">
                                    <span class="tod-bucket">@row.Label</span>
                                    <span class="tod-bar">
                                        <span class="tod-bar-fill"
                                              style="width: @(row.BarPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></span>
                                    </span>
                                    <span class="tod-value">@row.ValueLabel</span>
                                    <span class="tod-n">n=@row.Count</span>
                                </li>
                            }
                        </ul>
                        <p class="tod-verdict">@_sleepInsights.DurationVerdict</p>
                    </article>
                    </ChildContent></Explainable>
                </div>

                @if (_sleepInsights.EveningLabel is not null)
                {
                    <p class="tod-fact">@_sleepInsights.EveningLabel</p>
                }
            }
        </section>

        <section class="runs">
            <h2>Läufe nach Recovery</h2>
            @if (_runs.Count == 0)
            {
                <p class="insights-msg">Keine Läufe im Zeitraum.</p>
            }
            else
            {
                <ul class="run-list">
                    @foreach (var run in _runs)
                    {
                        <li class="run">
                            <span class="run-dot @run.RecoveryCss" title="Recovery"></span>
                            <span class="run-date">@run.Date</span>
                            <span class="run-kind">@run.Kind</span>
                            <span class="run-detail">@run.Detail</span>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>

@code {
    private const int WindowDays = 30;

    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    /// <summary>Bildet die stabile CssClass einer Metrik-Karte auf ihre Erklärungs-ID ab.</summary>
    private static MetricId CardMetric(string cssClass) => cssClass switch
    {
        "recovery" => MetricId.WhoopRecovery,
        "hrv" => MetricId.WhoopHrv,
        "rhr" => MetricId.WhoopRestingHeartRate,
        "sleep" => MetricId.WhoopSleep,
        "strain" => MetricId.WhoopStrain,
        "resp" => MetricId.WhoopRespiratoryRate,
        _ => throw new ArgumentOutOfRangeException(nameof(cssClass), cssClass, "Unbekannte Metrik-Karte."),
    };

    /// <summary>Y-Achsenbeschriftung fürs große Diagramm im Popup – aus dem Katalog.</summary>
    private static string CardYAxis(string cssClass) => MetricCatalog.Get(CardMetric(cssClass)).YAxis ?? "";

    private bool _connected;
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<WhoopMetricCard> _cards = [];
    private IReadOnlyList<WhoopRunRow> _runs = [];
    private WhoopSleepNight? _night;
    private IReadOnlyList<TimeOfDayCard> _todCards = [];
    private TimeOfDayMatrix? _todMatrix;
    private SleepInsightsView? _sleepInsights;
    private TrainingLoadView? _trainingLoad;
    private FitnessCurveView? _fitnessCurve;
    private RecoveryDriversView? _recoveryDrivers;

    protected override async Task OnInitializedAsync()
    {
        _connected = await Tokens.HasTokensAsync();
        if (!_connected)
        {
            _loading = false;
            return;
        }

        try
        {
            var now = Clock.UtcNow;
            var from = now.AddDays(-WindowDays);

            // Historie aus der DB (FA-9.10) – die Live-API bleibt nur Fallback, solange die
            // Tabelle leer ist (frisch deployt, erster Hintergrund-Sync läuft noch).
            var today = DateOnly.FromDateTime(TimeZoneInfo.ConvertTime(now, BerlinTz).DateTime);
            var history = await Metrics.GetRangeAsync(today.AddDays(-WindowDays), today);
            if (history.Count == 0)
            {
                history = await Whoop.GetHistoryAsync(from, now);
            }

            var workouts = await Whoop.GetWorkoutsAsync(from, now);
            _cards = WhoopInsightsBuilder.BuildCards(history);
            _night = WhoopInsightsBuilder.BuildSleepNight(history);
            _runs = WhoopInsightsBuilder.BuildRuns(workouts, history);

            // Tageszeit- und Schlafenszeiten-Auswertungen über die persistierte Historie
            // (FA-10.01/10.03) – bewusst kein Live-Fallback: ein Jahr je Reload wäre
            // API-Verschwendung.
            var yearWorkouts = await Workouts.GetRangeAsync(now.AddDays(-365), now);
            _todCards = WhoopInsightsBuilder.BuildTimeOfDayCards(yearWorkouts);
            _todMatrix = yearWorkouts.Count > 0
                ? WhoopInsightsBuilder.BuildTimeOfDayMatrix(yearWorkouts)
                : null;

            var yearMetrics = await Metrics.GetRangeAsync(today.AddDays(-365), today);
            _sleepInsights = WhoopInsightsBuilder.BuildSleepInsights(yearMetrics, yearWorkouts);
            _trainingLoad = WhoopInsightsBuilder.BuildTrainingLoad(yearMetrics);
            _recoveryDrivers = WhoopInsightsBuilder.BuildRecoveryDrivers(yearMetrics);

            // Fitness-Kurve aus den Strava-Lauf-Metriken (Projektion ohne Geometrie).
            _fitnessCurve = WhoopInsightsBuilder.BuildFitnessCurve(
                await RunRepo.GetRunSummariesAsync(now.AddDays(-365)));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
