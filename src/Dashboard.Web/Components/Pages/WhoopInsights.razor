@page "/whoop"
@rendermode InteractiveServer
@inject IWhoopProvider Whoop
@inject IWhoopTokenStore Tokens
@inject IClock Clock

<PageTitle>WHOOP – Auswertungen</PageTitle>

<div class="insights">
    <header class="insights-header">
        <a class="insights-back" href="/">← Dashboard</a>
        <h1>WHOOP · letzte @WindowDays Tage</h1>
    </header>

    @if (!_connected)
    {
        <p class="insights-msg">WHOOP nicht verbunden – <a href="/whoop/connect">jetzt verbinden</a>.</p>
    }
    else if (_loading)
    {
        <p class="insights-msg">Lade WHOOP-Daten …</p>
    }
    else if (_error is not null)
    {
        <p class="insights-msg insights-error">Konnte WHOOP-Daten nicht laden: @_error</p>
    }
    else
    {
        <section class="metric-grid">
            @foreach (var card in _cards)
            {
                <article class="metric-card">
                    <div class="metric-head">
                        <span class="metric-title">@card.Title</span>
                        <span class="metric-current">@card.Current<span class="metric-unit">@card.Unit</span></span>
                    </div>
                    <Sparkline Values="card.Values" CssClass="@card.CssClass" />
                    <div class="metric-stats">
                        <span>Ø @card.Avg</span>
                        <span>min @card.Min</span>
                        <span>max @card.Max</span>
                    </div>
                </article>
            }
        </section>

        <section class="runs">
            <h2>Läufe nach Recovery</h2>
            @if (_runs.Count == 0)
            {
                <p class="insights-msg">Keine Läufe im Zeitraum.</p>
            }
            else
            {
                <ul class="run-list">
                    @foreach (var run in _runs)
                    {
                        <li class="run">
                            <span class="run-dot @RecoveryCss(run.Recovery)" title="Recovery"></span>
                            <span class="run-date">@run.Date</span>
                            <span class="run-kind">@run.Kind</span>
                            <span class="run-detail">@run.Detail</span>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>

@code {
    private const int WindowDays = 30;

    private static readonly System.Globalization.CultureInfo German =
        System.Globalization.CultureInfo.GetCultureInfo("de-DE");

    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    private bool _connected;
    private bool _loading = true;
    private string? _error;
    private List<MetricCard> _cards = [];
    private List<RunRow> _runs = [];

    protected override async Task OnInitializedAsync()
    {
        _connected = await Tokens.HasTokensAsync();
        if (!_connected)
        {
            _loading = false;
            return;
        }

        try
        {
            var now = Clock.UtcNow;
            var from = now.AddDays(-WindowDays);
            var history = await Whoop.GetHistoryAsync(from, now);
            var workouts = await Whoop.GetWorkoutsAsync(from, now);
            _cards = BuildCards(history);
            _runs = BuildRuns(workouts, history);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static List<MetricCard> BuildCards(IReadOnlyList<WhoopDailyMetric> history) =>
    [
        Card("Recovery", "%", "recovery", history, m => m.RecoveryScore, 0),
        Card("HRV", "ms", "hrv", history, m => m.HrvMillis, 0),
        Card("Ruhepuls", "bpm", "rhr", history, m => m.RestingHeartRate, 0),
        Card("Schlaf", "h", "sleep", history, m => m.SleepHours, 1),
        Card("Tages-Strain", "", "strain", history, m => m.DayStrain, 1),
    ];

    private static MetricCard Card(
        string title, string unit, string css, IReadOnlyList<WhoopDailyMetric> history,
        Func<WhoopDailyMetric, double?> selector, int decimals)
    {
        var values = history.Select(selector).ToList();
        var present = values.Where(v => v.HasValue).Select(v => v!.Value).ToList();
        string Fmt(double v) => v.ToString("F" + decimals, German);

        return new MetricCard(
            title, unit, css, values,
            Current: present.Count > 0 ? Fmt(present[^1]) : "–",
            Avg: present.Count > 0 ? Fmt(present.Average()) : "–",
            Min: present.Count > 0 ? Fmt(present.Min()) : "–",
            Max: present.Count > 0 ? Fmt(present.Max()) : "–");
    }

    private static List<RunRow> BuildRuns(
        IReadOnlyList<WhoopWorkout> workouts, IReadOnlyList<WhoopDailyMetric> history)
    {
        var recoveryByDate = history
            .Where(m => m.RecoveryLevel is not null)
            .ToDictionary(m => m.Date, m => m.RecoveryLevel);

        var runs = new List<RunRow>();
        foreach (var workout in workouts.OrderByDescending(w => w.StartUtc))
        {
            var kind = WhoopHabitMapper.MapKind(workout);
            if (kind is not (HabitKind.Zone2Run or HabitKind.Vo2MaxIntervals))
            {
                continue;
            }

            var date = DateOnly.FromDateTime(TimeZoneInfo.ConvertTime(workout.StartUtc, BerlinTz).DateTime);
            var details = WhoopHabitMapper.BuildRunningDetails(workout);
            var detail = details is null
                ? $"{(int)workout.Duration.TotalMinutes} min"
                : $"{details.DurationMinutes} min · {details.PaceMinPerKm.ToString("0.00", German)} min/km";
            var label = kind == HabitKind.Vo2MaxIntervals ? "VO2max" : "Zone 2";

            runs.Add(new RunRow(
                date.ToString("dd.MM.", German), label, detail, recoveryByDate.GetValueOrDefault(date)));
        }

        return runs;
    }

    private static string RecoveryCss(WhoopRecoveryLevel? level) => level switch
    {
        WhoopRecoveryLevel.High => "recovery-high",
        WhoopRecoveryLevel.Medium => "recovery-medium",
        WhoopRecoveryLevel.Low => "recovery-low",
        _ => "recovery-none"
    };

    private sealed record MetricCard(
        string Title, string Unit, string CssClass, IReadOnlyList<double?> Values,
        string Current, string Avg, string Min, string Max);

    private sealed record RunRow(string Date, string Kind, string Detail, WhoopRecoveryLevel? Recovery);
}
