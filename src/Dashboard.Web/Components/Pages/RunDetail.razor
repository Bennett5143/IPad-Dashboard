@page "/runs/{Id:long}"
@layout MainLayout
@rendermode InteractiveServer
@inject IRunRepository RunRepository
@inject IRouteClusterStore RouteClusters
@inject IClock Clock

<PageTitle>@(_header?.Name ?? "Lauf")</PageTitle>

<div class="run-detail">
    <header class="runs-header">
        <a class="runs-back" href="/runs">← Läufe</a>
    </header>

    @if (_notFound)
    {
        <p class="runs-msg">Lauf nicht gefunden.</p>
    }
    else if (_header is not null)
    {
        <h1 class="run-title">@_header.Name</h1>
        <p class="run-subtitle">
            @_header.Date
            @if (_cluster is not null)
            {
                <span class="run-route-badge">@_cluster.Name</span>
            }
        </p>

        <dl class="run-stats">
            <div><dt>Distanz</dt><dd>@_header.Distance</dd></div>
            <div><dt>Dauer</dt><dd>@_header.Duration</dd></div>
            <div><dt>Pace</dt><dd>@_header.Pace</dd></div>
            <div><dt>Ø Herzfrequenz</dt><dd>@_header.HeartRate</dd></div>
            <div><dt>Höhenmeter</dt><dd>@_header.Elevation</dd></div>
        </dl>

        @if (_bestEfforts.Count > 0)
        {
            <section class="run-efforts">
                <h2>Bestzeiten in diesem Lauf</h2>
                <Explainable Id="MetricId.RunBestEfforts"><ChildContent>
                <div class="effort-chips">
                    @foreach (var effort in _bestEfforts)
                    {
                        <div class="effort-chip">
                            <span class="effort-distance">@effort.Distance</span>
                            <span class="effort-time">@effort.Time</span>
                        </div>
                    }
                </div>
                </ChildContent></Explainable>
            </section>
        }

        @if (_profile is null || _profile.IsEmpty)
        {
            <p class="runs-msg">Kein Verlaufsprofil verfügbar – für diesen Lauf wurden noch keine Streams geladen.</p>
        }
        else
        {
            <section class="run-profiles">
                @if (_profile.HasPace)
                {
                    @ProfileBlock("Pace", "pace", "min/km · niedriger = schneller", "Pace (min/km)", MetricId.RunPaceProfile, _profile.Pace, invert: true)
                }
                @if (_profile.HasElevation)
                {
                    @ProfileBlock("Höhe", "elevation", "Meter", "Höhe (m)", MetricId.RunElevationProfile, _profile.Elevation, invert: false)
                }
                @if (_profile.HasHeartRate)
                {
                    @ProfileBlock("Herzfrequenz", "heartrate", "bpm", "Herzfrequenz (bpm)", MetricId.RunHeartRateProfile, _profile.HeartRate, invert: false)
                }
            </section>
        }

        <p class="run-detail-link"><a href="/heatmap">Auf der Heatmap ansehen →</a></p>
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    private bool _notFound;
    private RunDetailHeader? _header;
    private RunProfile? _profile;
    private RouteClusterInfo? _cluster;
    private IReadOnlyList<BestEffortRow> _bestEfforts = [];

    protected override async Task OnInitializedAsync()
    {
        var run = await RunRepository.GetRunAsync(Id);
        if (run is null)
        {
            _notFound = true;
            return;
        }

        _header = RunViewBuilder.BuildDetailHeader(run);
        _profile = RunProfileBuilder.Build(run);
        _bestEfforts = RunViewBuilder.BuildBestEfforts(BestEffortsCalculator.Compute(run));
        _cluster = await RouteClusters.GetClusterForRunAsync(Id);
    }

    private RenderFragment ProfileBlock(
        string title, string css, string hint, string yLabel, MetricId metricId,
        IReadOnlyList<double?> values, bool invert) => __builder =>
    {
        var present = values.Where(v => v is not null).Select(v => v!.Value).ToList();
        var (min, max) = present.Count > 0 ? (present.Min(), present.Max()) : (0, 0);
        var rangeStart = Format(invert ? max : min, css);
        var rangeEnd = Format(invert ? min : max, css);

        <text>
            <Explainable Id="metricId">
                <ChildContent>
                    <article class="run-profile">
                        <div class="run-profile-head">
                            <span class="run-profile-title">@title</span>
                            <span class="run-profile-hint">@hint</span>
                        </div>
                        <Sparkline Values="values" CssClass="@($"profile-{css}")" />
                        <div class="run-profile-range">
                            <span>@rangeStart</span>
                            <span>@rangeEnd</span>
                        </div>
                    </article>
                </ChildContent>
                <Detail>
                    <ChartFrame XLabel="Distanz (Lauf-Verlauf)" YLabel="@yLabel"
                                RangeStart="@rangeStart" RangeEnd="@rangeEnd">
                        <Sparkline Values="values" CssClass="@($"profile-{css}")" />
                    </ChartFrame>
                </Detail>
            </Explainable>
        </text>;
    };

    private static string Format(double value, string css) => css switch
    {
        "pace" => FormatPace(value),
        _ => value.ToString("0", System.Globalization.CultureInfo.GetCultureInfo("de-DE"))
    };

    private static string FormatPace(double minPerKm)
    {
        var minutes = (int)minPerKm;
        var seconds = (int)Math.Round((minPerKm - minutes) * 60, MidpointRounding.AwayFromZero);
        if (seconds == 60)
        {
            minutes++;
            seconds = 0;
        }

        return $"{minutes}:{seconds:00}";
    }
}
