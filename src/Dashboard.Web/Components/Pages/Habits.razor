@page "/habits"
@layout MainLayout
@rendermode InteractiveServer
@inject IHabitEntryRepository HabitRepo
@inject IClock Clock

<PageTitle>Habit-Verlauf</PageTitle>

<div class="habits-page">
    <header class="habits-header">
        <h1>Habit-Verlauf</h1>
    </header>

    <div class="habit-tabs" role="group" aria-label="Habit">
        <button class="@(_kind is null ? "active" : null)" @onclick="() => Select(null)">Alle</button>
        @foreach (var kind in _kinds)
        {
            <button class="@(_kind == kind ? "active" : null)" @onclick="() => Select(kind)">
                @HabitsHeatmapBuilder.Label(kind)
            </button>
        }
    </div>

    @if (_view is not null)
    {
        <div class="habit-summary">
            <div class="stat"><span class="stat-value">@_view.YearTotal</span><span class="stat-label">@(_year) gesamt</span></div>
            <div class="stat"><span class="stat-value">@_view.CurrentWeek</span><span class="stat-label">diese Woche</span></div>
            @if (_kind is { } selected)
            {
                <Explainable Id="MetricId.HabitStreaks"><ChildContent>
                <div class="stat">
                    <span class="stat-value">@_weeklyStreak.Current</span>
                    <span class="stat-label">Wochen-Serie · Rekord @_weeklyStreak.Longest</span>
                </div>
                </ChildContent></Explainable>
            }
            else
            {
                <Explainable Id="MetricId.HabitStreaks"><ChildContent>
                <div class="stat">
                    <span class="stat-value">@_dailyStreak.Current</span>
                    <span class="stat-label">Tage-Serie · Rekord @_dailyStreak.Longest</span>
                </div>
                </ChildContent></Explainable>
            }
        </div>

        <Explainable Id="MetricId.HabitHeatmap"><ChildContent>
        <div class="heat-scroll">
            <div class="heat-months">
                @foreach (var month in _view.Months)
                {
                    <span class="heat-month" style="grid-column: @(month.Week + 1)">@month.Label</span>
                }
            </div>
            <div class="heat-grid">
                @foreach (var cell in _view.Cells)
                {
                    <span class="heat-cell lvl-@cell.Bucket"
                          style="grid-column: @(cell.Week + 1); grid-row: @(cell.Weekday + 1)"
                          title="@cell.Title"></span>
                }
            </div>
        </div>

        <div class="heat-legend">
            <span>weniger</span>
            <span class="heat-cell lvl-0"></span>
            <span class="heat-cell lvl-1"></span>
            <span class="heat-cell lvl-2"></span>
            <span class="heat-cell lvl-3"></span>
            <span class="heat-cell lvl-4"></span>
            <span>mehr</span>
        </div>
        </ChildContent></Explainable>

        <section class="weeks">
            <h2>Letzte 12 Wochen</h2>
            <div class="week-bars">
                @foreach (var bar in _view.WeeklyBars)
                {
                    <div class="week-bar" title="Woche ab @bar.Label: @bar.Count">
                        <div class="week-bar-track">
                            <div class="week-bar-fill"
                                 style="height: @(bar.BarPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                        </div>
                        <span class="week-bar-count">@bar.Count</span>
                        <span class="week-bar-label">@bar.Label</span>
                    </div>
                }
            </div>
        </section>
    }
</div>

@code {
    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    private readonly HabitKind[] _kinds = Enum.GetValues<HabitKind>();
    private HabitKind? _kind;
    private int _year;
    private IReadOnlyDictionary<HabitKind, IReadOnlySet<DateOnly>> _done =
        new Dictionary<HabitKind, IReadOnlySet<DateOnly>>();
    private HabitHeatmapView? _view;
    private StreakResult _dailyStreak = new(0, 0);
    private StreakResult _weeklyStreak = new(0, 0);

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(TimeZoneInfo.ConvertTime(Clock.UtcNow, BerlinTz).DateTime);
        _year = today.Year;
        var from = today.AddDays(-HabitsHeatmapBuilder.Weeks * 7);
        _done = await HabitRepo.GetEntryDatesAsync(from, today);
        // Tages-Serie über alle Habits zusammen – unabhängig vom gewählten Tab.
        _dailyStreak = HabitStreakCalculator.DailyStreak(
            _done.SelectMany(kv => kv.Value).Distinct(), today);
        Rebuild(today);
    }

    private void Select(HabitKind? kind)
    {
        _kind = kind;
        var today = DateOnly.FromDateTime(TimeZoneInfo.ConvertTime(Clock.UtcNow, BerlinTz).DateTime);
        Rebuild(today);
    }

    private void Rebuild(DateOnly today)
    {
        _view = HabitsHeatmapBuilder.Build(_done, _kind, today);
        _weeklyStreak = _kind is { } kind
            ? HabitStreakCalculator.WeeklyStreak(
                _done.TryGetValue(kind, out var set) ? set : new HashSet<DateOnly>(), today)
            : new StreakResult(0, 0);
    }
}
