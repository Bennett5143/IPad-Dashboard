@inject Dashboard.Domain.Time.IClock Clock
<!DOCTYPE html>
<html lang="de" data-theme="@_theme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no" />
    <meta name="color-scheme" content="@(_night ? "dark" : "light")" />
    <meta name="theme-color" content="@(_night ? "#121210" : "#f5f2eb")" />
    <base href="/" />
    <ResourcePreloader />
    @* Command-Center-Typografie: Space Grotesk (Text/Kennzahlen) + JetBrains Mono
       (Labels/Zeiten). Fällt ohne Netz sauber auf die System-Schrift zurück. *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Dashboard.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    @* Day/night by the wall clock (night 20:00–08:00). Pure JS — no Blazor circuit —
       so the kiosk flips on its own device time and nothing here can fault interactivity.
       App.razor sets the initial data-theme server-side above, so there is no flash. *@
    <script>
        (function () {
            function apply() {
                var h = new Date().getHours();
                var night = h >= 20 || h < 8;
                var root = document.documentElement;
                root.setAttribute('data-theme', night ? 'night' : 'eink');
                root.style.colorScheme = night ? 'dark' : 'light';
            }
            apply();
            setInterval(apply, 60000);
        })();
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    private static readonly TimeZoneInfo BerlinTz =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    // Server-computed initial theme so the first paint is already day/night (no flash);
    // the inline script above keeps a running kiosk in sync on the device clock.
    private string _theme = ThemeResolver.Day;
    private bool _night;

    protected override void OnInitialized()
    {
        _theme = ThemeResolver.Resolve(Clock.UtcNow, BerlinTz);
        _night = _theme == ThemeResolver.Night;
    }
}
