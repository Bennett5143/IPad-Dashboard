@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject NavigationManager Nav

@* Hub-&-spoke top nav for MainLayout pages: only "back to Home", plus the Fitness
   siblings when the current page is in the Fitness area. No lateral cross-area jumps. *@
<nav class="subnav">
    <a class="subnav-home" href="/">← Home</a>
    @if (_fitness)
    {
        <div class="subnav-links">
            @foreach (var (href, label) in Area.Fitness)
            {
                <NavLink href="@href" Match="NavLinkMatch.Prefix">@label</NavLink>
            }
        </div>
    }
</nav>

@code {
    private bool _fitness;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateArea();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateArea();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateArea() => _fitness = Area.IsFitness(Nav.ToBaseRelativePath(Nav.Uri));

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
