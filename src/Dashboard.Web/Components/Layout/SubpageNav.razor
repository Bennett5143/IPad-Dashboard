@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav

@* Hub-&-spoke top nav for MainLayout pages: only "back to Home", plus the Fitness
   siblings when the current page is in the Fitness area. No lateral cross-area jumps.
   Read from the current URL each render (static layout) — no LocationChanged subscription. *@
<nav class="subnav">
    <a class="subnav-home" href="/">← Home</a>
    @if (Fitness)
    {
        <div class="subnav-links">
            @foreach (var (href, label) in Area.Fitness)
            {
                <NavLink href="@href" Match="NavLinkMatch.Prefix">@label</NavLink>
            }
        </div>
    }
</nav>

@code {
    private bool Fitness => Area.IsFitness(Nav.ToBaseRelativePath(Nav.Uri));
}
