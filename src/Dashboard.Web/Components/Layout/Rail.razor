@using Microsoft.AspNetCore.Components.Routing

@* Gruppierte, vertikale Kiosk-Navigation (linke Rail der Detailseiten). Ersetzt auf den
   Kiosk-Seiten die flache SubpageNav; Aktiv-State kommt von NavLink (.active). *@
<nav class="rail">
    <div class="rail-brand">
        <span class="rail-brand-chip" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 16 16">
                <rect x="3" y="3" width="4.4" height="4.4" rx="1" fill="#5fce97" />
                <rect x="8.6" y="3" width="4.4" height="4.4" rx="1" fill="#c47b38" />
                <rect x="3" y="8.6" width="4.4" height="4.4" rx="1" fill="#e2b45f" />
                <rect x="8.6" y="8.6" width="4.4" height="4.4" rx="1" fill="#4fbdb0" />
            </svg>
        </span>
        <span class="rail-brand-label">Kiosk</span>
    </div>

    <div class="rail-group">
        <NavLink class="rail-item" href="/" Match="NavLinkMatch.All">
            <span class="rail-dot"></span><span>Übersicht</span>
        </NavLink>
    </div>

    <div class="rail-group">
        <span class="rail-group-label">Alltag</span>
        <NavLink class="rail-item" href="/weather" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Wetter</span>
        </NavLink>
        <NavLink class="rail-item" href="/hvv" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Abfahrten</span>
        </NavLink>
    </div>

    <div class="rail-group">
        <span class="rail-group-label">Fitness</span>
        <NavLink class="rail-item" href="/whoop" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>WHOOP</span>
        </NavLink>
        <NavLink class="rail-item" href="/runs" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Läufe</span>
        </NavLink>
        <NavLink class="rail-item" href="/heatmap" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Heatmap</span>
        </NavLink>
        <NavLink class="rail-item" href="/habits" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Habits</span>
        </NavLink>
    </div>

    <div class="rail-group">
        <span class="rail-group-label">Interessen</span>
        <NavLink class="rail-item" href="/football" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Fußball</span>
        </NavLink>
        <NavLink class="rail-item" href="/crypto" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Krypto</span>
        </NavLink>
    </div>

    <div class="rail-group">
        <span class="rail-group-label">System</span>
        <NavLink class="rail-item" href="/status" Match="NavLinkMatch.Prefix">
            <span class="rail-dot"></span><span>Status</span>
        </NavLink>
    </div>
</nav>
