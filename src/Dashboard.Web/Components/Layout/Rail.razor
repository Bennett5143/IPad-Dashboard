@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav

@* Hub-&-spoke rail for detail pages: back to Home is the only cross-area move.
   Fitness is the one area that also links its own sub-pages (WHOOP/Läufe/Heatmap/
   Habits); every other area is a single spoke, so it just offers "back to Home".
   Rendered in the static layout, so the area is read from the current URL each
   render — no LocationChanged subscription (which is a footgun in static SSR). *@
<nav class="rail">
    <div class="rail-group">
        <a class="rail-item rail-home" href="/">
            <span class="rail-back" aria-hidden="true">←</span><span>Home</span>
        </a>
    </div>

    @if (Fitness)
    {
        <div class="rail-group">
            <span class="rail-group-label">Fitness</span>
            @foreach (var (href, label) in Area.Fitness)
            {
                <NavLink class="rail-item" href="@href" Match="NavLinkMatch.Prefix">
                    <span class="rail-dot"></span><span>@label</span>
                </NavLink>
            }
        </div>
    }
</nav>

@code {
    private bool Fitness => Area.IsFitness(Nav.ToBaseRelativePath(Nav.Uri));
}
