{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dashboard-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ],
    "Properties": {
      "Application": "Dashboard.Web"
    }
  },
  "AllowedHosts": "*",
  "Weather": {
    "Language": "de",
    "Units": "metric",
    "RefreshInterval": "00:15:00",
    "HourlyCount": 5
  },
  "Calendar": {
    "TimeZone": "Europe/Berlin",
    "RefreshInterval": "00:30:00",
    "WindowDays": 45,
    "HttpTimeoutSeconds": 20,
    "_IcsUrls": "Veröffentlichte .ics-Abo-URL(s) NICHT hier, sondern in der gitignored appsettings.Local.json (Vorlage: appsettings.Local.json.example).",
    "IcsUrls": []
  },
  "Hvv": {
    "Endpoint": "https://www.hvv.de/geofox/departureList",
    "UserAgent": "ipad-kiosk-dashboard/1.0 (+https://github.com/Bennett5143/IPad-Dashboard)",
    "Version": 47,
    "PollIntervalSeconds": 60,
    "MaxDepartures": 12,
    "_Stations": "Haltestellen NICHT hier, sondern in der gitignored appsettings.Local.json (Vorlage: appsettings.Local.json.example).",
    "Stations": []
  },
  "Football": {
    "RefreshInterval": "00:20:00",
    "InterCallDelay": "00:00:08",
    "RecentCount": 3,
    "UpcomingCount": 3,
    "LeagueCodes": [ "PL", "PD", "BL1", "SA", "FL1" ],
    "ChampionsLeagueCode": "CL",
    "_Tournaments": "Aktiv-Fenster (UTC) für EM/WM; nur aktive werden abgerufen. Daten Jahre im Voraus pflegbar.",
    "Tournaments": [
      { "Code": "WC", "Name": "WM 2026", "From": "2026-06-11T00:00:00Z", "To": "2026-07-19T23:59:59Z" }
    ],
    "_Teams": "Vereine + ApiKey NICHT hier: Teams in der gitignored appsettings.Local.json (Vorlage: .example), ApiKey in User-Secrets (Football:ApiKey).",
    "Teams": []
  },
  "Crypto": {
    "MarketBaseUrl": "https://api.coingecko.com/",
    "SentimentBaseUrl": "https://api.alternative.me/",
    "VsCurrency": "eur",
    "SummaryCoinId": "bitcoin",
    "RefreshInterval": "00:05:00",
    "_CoinIds": "CoinGecko-Slugs der Watchlist; hier sinnvolle Defaults, in appsettings.Local.json überschreibbar (keine sensiblen Daten).",
    "CoinIds": [ "bitcoin", "ethereum", "solana", "cardano", "ripple" ]
  },
  "Strava": {
    "RedirectUri": "http://localhost:5235/strava/callback",
    "Scope": "activity:read_all",
    "BaseUrl": "https://www.strava.com/",
    "PerPage": 200,
    "SyncInterval": "00:30:00"
  },
  "Whoop": {
    "RedirectUri": "https://localhost:7204/whoop/callback",
    "Scope": "offline read:recovery read:sleep read:cycles read:workout read:profile",
    "BaseUrl": "https://api.prod.whoop.com/",
    "RefreshInterval": "00:30:00",
    "BackfillDays": 365
  },
  "Tiles": {
    "UrlTemplate": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
    "UserAgent": "ipad-kiosk-dashboard/1.0 (+https://github.com/Bennett5143/IPad-Dashboard)",
    "CacheDirectory": "tile-cache",
    "MaxZoom": 19
  },
  "Crests": {
    "AllowedHosts": [ "crests.football-data.org" ],
    "UserAgent": "ipad-kiosk-dashboard/1.0 (+https://github.com/Bennett5143/IPad-Dashboard)",
    "CacheDirectory": "crest-cache"
  }
}
