{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dashboard-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ],
    "Properties": {
      "Application": "Dashboard.Web"
    }
  },
  "AllowedHosts": "*",
  "Weather": {
    "Latitude": 53.5511,
    "Longitude": 9.9937,
    "Language": "de",
    "Units": "metric",
    "RefreshInterval": "00:15:00",
    "HourlyCount": 4
  },
  "Football": {
    "BaseUrl": "https://api.football-data.org/",
    "RefreshInterval": "00:30:00",
    "RecentCount": 3,
    "UpcomingCount": 2,
    "Teams": [
      { "Name": "Real Madrid", "TeamId": 86, "CompetitionCode": "PD" },
      { "Name": "HSV", "TeamId": 7, "CompetitionCode": "BL1" }
    ]
  },
  "Hvv": {
    "Endpoint": "https://www.hvv.de/geofox/departureList",
    "UserAgent": "ipad-kiosk-dashboard/1.0 (+https://github.com/Bennett5143/IPad-Dashboard)",
    "Version": 47,
    "PollIntervalSeconds": 60,
    "MaxDepartures": 6,
    "Stations": [
      {
        "Name": "Lühmannstraße",
        "MasterId": "Master:42026",
        "City": "Hamburg",
        "Lines": [
          { "Line": "42", "Direction": "Hafen Harburg" }
        ]
      },
      {
        "Name": "Lichtenauerweg",
        "MasterId": "Master:42008",
        "City": "Hamburg",
        "Lines": [
          { "Line": "143", "Direction": "Hirschkäferweg" }
        ]
      },
      {
        "Name": "Harburg Rathaus",
        "MasterId": "Master:40950",
        "City": "Hamburg",
        "Lines": [
          { "Line": "S3", "Direction": "Pinneberg" }
        ],
        "MaxList": 60
      }
    ]
  },
  "Strava": {
    "RedirectUri": "http://localhost:5235/strava/callback",
    "Scope": "activity:read_all",
    "BaseUrl": "https://www.strava.com/",
    "PerPage": 200,
    "SyncInterval": "00:30:00"
  }
}
