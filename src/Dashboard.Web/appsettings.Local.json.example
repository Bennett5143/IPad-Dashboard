// Vorlage für lokale, NICHT versionierte Overrides.
//
// Kopieren nach  appsettings.Local.json  (gitignored) und mit den eigenen Werten füllen.
// Wird umgebungsunabhängig geladen (auch in Production / auf dem Raspberry Pi) und über-
// schreibt die Werte aus appsettings.json. So bleiben private/standortbezogene Daten
// (Wetter-Standort, Karten-Zentrierung, beobachtete Vereine, HVV-Haltestellen) aus dem
// öffentlichen Repo. Die Werte unten sind Platzhalter – durch eigene ersetzen.
{
  // Wetter-Standort (Dezimalgrad). Ohne Angabe greift ein generischer Default im Code.
  "Weather": {
    "Latitude": 0.0,
    "Longitude": 0.0
  },

  // Start-Zentrierung der Lauf-Heatmap = dein Haupt-Laufgebiet (Dezimalgrad) + Zoom (3–19).
  "Map": {
    "Latitude": 0.0,
    "Longitude": 0.0,
    "Zoom": 13
  },

  // Beobachtete Fußball-Vereine (football-data.org-IDs/-Codes). Der ApiKey gehört in User-Secrets
  // (Football:ApiKey, Header X-Auth-Token), NICHT hierher. Nur Free-Tier-Wettbewerbe verwenden:
  // PL, PD, BL1, SA, FL1, CL, EC (EM), WC (WM) – kein nationaler Pokal/2. Liga.
  //
  // "CompetitionCode" = die Liga für Tabellenplatz/-zeile des Vereins. "Competitions" = alle
  // Wettbewerbe, aus denen Spiele geholt werden (z. B. ["PD","CL"]); leer = nur CompetitionCode.
  // Jeder Wettbewerb wird pro Refresh genau EINMAL abgefragt (Vereine werden client-seitig daraus
  // aufgelöst) – 12 Vereine über 5 Ligen + CL ⇒ ~11 Calls; InterCallDelay (appsettings.json) hält
  // das ≤8/min unter dem Free-Tier-Limit (10/min). Die Top-5-Ligatabellen auf /football kommen aus
  // appsettings.json → Football:LeagueCodes (unabhängig von den hier getrackten Vereinen). Die
  // Champions League (Ligaphase + K.o.-Bracket) und EM/WM-Turnierfenster sind ebenfalls app-weit in
  // appsettings.json konfiguriert (Football:ChampionsLeagueCode / Football:Tournaments) – nicht hier.
  "Football": {
    "Teams": [
      { "Name": "Real Madrid", "TeamId": 86, "CompetitionCode": "PD", "Competitions": [ "PD", "CL" ] },
      { "Name": "Barcelona",   "TeamId": 81, "CompetitionCode": "PD", "Competitions": [ "PD", "CL" ] },
      { "Name": "Liverpool",   "TeamId": 64, "CompetitionCode": "PL", "Competitions": [ "PL", "CL" ] },
      { "Name": "HSV",         "TeamId": 7,  "CompetitionCode": "BL1", "Competitions": [ "BL1" ] }
    ]
  },

  // HVV-Haltestellen in deiner Nähe. MasterId über den HVV-checkName-Endpoint bzw. den
  // Stations-Generator; "Lines" filtert nach Linie (+ optional Richtung als Teilstring).
  // "Group": Linien/Richtungen gleicher Gruppe teilen sich ein Kontingent; "DeparturesPerGroup"
  // = wie viele Abfahrten je Gruppe behalten werden. Für BEIDE Endstationen einer Linie je
  // Richtung einen eigenen Filter mit eigener Group anlegen (sonst kann NextPerGroup eine
  // Richtung verdrängen). Die Summary-Kachel auf der Hauptseite zeigt pro Haltestelle den
  // nächsten BUS (S-/U-Bahn etc. erscheinen nur auf /hvv), soonest-first; die Detailseite
  // /hvv zeigt alle Stationen mit den vollen Listen je Verkehrsmittel.
  "Hvv": {
    "Stations": [
      {
        "Name": "Beispielhaltestelle A",
        "MasterId": "Master:00000",
        "City": "Hamburg",
        "DeparturesPerGroup": 1,
        "Lines": [
          { "Line": "42", "Direction": "Hafen Harburg",   "Group": "42 Hafen" },
          { "Line": "42", "Direction": "Harburg Rathaus", "Group": "42 Rathaus" }
        ]
      },
      {
        "Name": "Beispielhaltestelle B",
        "MasterId": "Master:00001",
        "City": "Hamburg",
        "DeparturesPerGroup": 1,
        "Lines": [
          { "Line": "143", "Group": "143/443" },
          { "Line": "443", "Group": "143/443" }
        ]
      },
      {
        "Name": "Beispielbahnhof",
        "MasterId": "Master:00002",
        "City": "Hamburg",
        "DeparturesPerGroup": 1,
        "Lines": [
          { "Line": "S3", "Direction": "Pinneberg" }
        ]
      }
    ]
  },

  // Apple-/iCloud-Kalender als veröffentlichte .ics-Abo-URL(s). In der Kalender-App den
  // Kalender „Öffentlich freigeben" und den erzeugten webcal://- bzw. https://-Link hier
  // eintragen (mehrere möglich). Kein Passwort nötig; ein echtes CalDAV-Konto-Passwort
  // gehörte stattdessen in User-Secrets. Timezone/Intervall/Fenster stehen in appsettings.json.
  "Calendar": {
    "IcsUrls": [
      "https://p00-caldav.icloud.com/published/2/XXXXXXXXXXXXXXXXXXXXXXXX"
    ]
  },

  // Krypto-Watchlist (optional). Beide Quellen sind frei & schlüssellos (CoinGecko +
  // alternative.me) – kein Secret nötig. Sinnvolle Defaults stehen schon in appsettings.json
  // (Crypto:CoinIds); hier nur überschreiben, wenn du eine andere Auswahl willst. "CoinIds" =
  // CoinGecko-Slugs (nicht Symbole), "SummaryCoinId" = die Münze der Hauptseiten-Kachel.
  "Crypto": {
    "CoinIds": [ "bitcoin", "ethereum", "solana", "cardano", "ripple" ],
    "SummaryCoinId": "bitcoin"
  }
}
